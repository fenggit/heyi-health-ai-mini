<view wx:if="{{show}}" class="popup-wrap">
  <!-- 遮罩 -->
  <view class="popup-mask" bindtap="onMaskTap" />

  <!-- 卡片 -->
  <view class="popup-card">
    <!-- 标题 -->
    <text class="popup-title">{{title}}</text>

    <!-- 可滚动内容 -->
    <scroll-view class="popup-scroll" scroll-y>
      <text class="popup-content">{{content}}</text>
    </scroll-view>

    <!-- 确认按钮 -->
    <view class="popup-btn" bindtap="onConfirm">
      <text class="popup-btn-text">我已了解</text>
    </view>
  </view>
</view>
