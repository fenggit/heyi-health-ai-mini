.my-checkbox {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.my-checkbox__icon {
  width: 100%;
  height: 100%;
  display: block;
}

/* circle 模式：用于列表选择项，48rpx */
.my-checkbox--circle {
  width: 48rpx;
  height: 48rpx;
}

/* square 模式：用于协议勾选，32rpx，保留原有方形外观 */
.my-checkbox--square {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  border: 2rpx solid #94a3b8;
  background: transparent;
  box-sizing: border-box;
  overflow: hidden;
}

.my-checkbox--square.my-checkbox--checked {
  border-color: transparent;
  background: linear-gradient(135deg, #4EFFE2 0%, #CEF94C 100%);
}

/* square 模式下图标覆盖整个区域 */
.my-checkbox--square .my-checkbox__icon {
  width: 100%;
  height: 100%;
}

.my-checkbox--disabled {
  opacity: 0.4;
}
