:host {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  vertical-align: middle;
}

.my-checkbox {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.my-checkbox__icon {
  width: 100%;
  height: 100%;
  display: block;
  flex-shrink: 0;
}

/* circle 模式：用于列表选择项，48rpx */
.my-checkbox--circle {
  width: 48rpx;
  height: 48rpx;
}

/* square 模式：用于协议勾选，32rpx，完全由图片表现状态 */
.my-checkbox--square {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

/* square 模式下图标覆盖整个区域 */
.my-checkbox--square .my-checkbox__icon {
  width: 32rpx;
  height: 32rpx;
}

.my-checkbox--disabled {
  opacity: 0.4;
}
