.dock-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  height: calc(146rpx + env(safe-area-inset-bottom));
}

.dock-base {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 750rpx;
  height: calc(118rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  box-shadow: 0 -8rpx 30rpx rgba(145, 156, 172, 0.08);
}

.dock-content {
  position: absolute;
  left: 50%;
  bottom: env(safe-area-inset-bottom);
  transform: translateX(-50%);
  width: 750rpx;
  height: 146rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 10rpx 24rpx 0;
  box-sizing: border-box;
}

.dock-side {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  width: 262rpx;
  padding-top: 22rpx;
}

.dock-tab {
  position: relative;
  width: 112rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dock-tab__badge {
  position: absolute;
  top: 8rpx;
  left: 26rpx;
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: rgba(181, 242, 192, 0.9);
}

.dock-tab__text {
  position: relative;
  z-index: 1;
  color: #a9b6c8;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 500;
}

.dock-tab--active .dock-tab__text {
  color: #1d2d49;
  font-size: 28rpx;
  font-weight: 700;
}

.dock-center {
  position: relative;
  width: 150rpx;
  height: 118rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.dock-center__cap {
  position: absolute;
  top: 12rpx;
  left: 50%;
  width: 108rpx;
  height: 28rpx;
  transform: translateX(-50%);
  border-top-left-radius: 54rpx;
  border-top-right-radius: 54rpx;
  background: #ffffff;
}

.dock-center__button {
  position: relative;
  z-index: 1;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #1fd85c 0%, #08c84e 100%);
  box-shadow:
    inset 0 0 0 10rpx rgba(44, 219, 101, 0.75),
    0 8rpx 16rpx rgba(10, 205, 77, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.dock-center__icon {
  width: 48rpx;
  height: 48rpx;
}
