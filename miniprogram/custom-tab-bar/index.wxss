.dock-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  height: calc(146rpx + env(safe-area-inset-bottom));
}

.dock-base {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 750rpx;
  height: calc(118rpx + env(safe-area-inset-bottom));
}

.dock-base__bg {
  width: 750rpx;
  height: 118rpx;
  display: block;
}

.dock-base__safe {
  width: 750rpx;
  height: env(safe-area-inset-bottom);
  background: #ffffff;
}

.dock-content {
  position: absolute;
  left: 50%;
  bottom: env(safe-area-inset-bottom);
  transform: translateX(-50%);
  width: 750rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx 24rpx 0;
  box-sizing: border-box;
}

.dock-side {
  display: flex;
  align-items: flex-start;
  justify-content: space-evenly;
  flex: 1;
  padding-top: 22rpx;
}

.dock-tab {
  position: relative;
  width: 112rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dock-tab__badge {
  position: absolute;
  top: 8rpx;
  left: 26rpx;
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: rgba(181, 242, 192, 0.9);
}

.dock-tab__text {
  position: relative;
  z-index: 1;
  color: #94a3b8;
  font-size: 15px;
  line-height: 1.2;
  font-weight: 500;
}

.dock-tab--active .dock-tab__text {
  color: #1e293b;
  font-size: 15px;
  font-weight: 700;
}

.dock-center {
  position: relative;
  width: 150rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.dock-center__button {
  position: relative;
  z-index: 1;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #1fd85c 0%, #08c84e 100%);
  box-shadow:
    inset 0 0 0 10rpx rgba(44, 219, 101, 0.75),
    0 8rpx 16rpx rgba(10, 205, 77, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.dock-center__icon {
  width: 48rpx;
  height: 48rpx;
}
