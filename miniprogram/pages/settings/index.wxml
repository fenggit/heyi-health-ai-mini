<view class="setting-page design-page page-with-nav">
  <image class="page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <view class="mini-nav__title">{{navTitle}}</view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="page-wrap page-wrap--no-title">
    <view class="glass-card setting-main-card">
      <view class="setting-head">偏好设置</view>

      <view class="setting-switch-row">
        <view>
          <view class="setting-switch-title">消息通知</view>
          <view class="setting-switch-desc">接收健康提醒和活动通知</view>
        </view>
        <switch color="#19bf55" checked="{{notifyEnabled}}" bindchange="onNotifyChange" />
      </view>

      <view class="setting-switch-row">
        <view>
          <view class="setting-switch-title">深色模式</view>
          <view class="setting-switch-desc">接收健康提醒和活动通知</view>
        </view>
        <switch color="#19bf55" checked="{{darkModeEnabled}}" bindchange="onDarkModeChange" />
      </view>

      <view class="setting-tip">提示：开启消息通知后，您将及时收到体质调理建议、食养方案更新和专属优惠活动信息。</view>
    </view>

    <view class="setting-bottom">
      <view class="setting-logout" bindtap="logout">退出登录</view>
    </view>
  </view>
</view>
