.my-plan-screen {
  background: #f3f4f8;
}

.my-plan-screen__bg {
  position: absolute;
  left: 50%;
  top: 0;
  width: 750rpx;
  transform: translateX(-50%);
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.my-plan-scroll {
  position: relative;
  z-index: 1;
}

.my-plan-nav__title {
  margin-left: 8rpx;
  color: #1e293b;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
}

.my-plan-wrap {
  width: 702rpx;
  margin: 0 auto;
}

.my-plan-hero {
  padding: 22rpx 24rpx 0;
}

.my-plan-hero__title {
  display: block;
  color: #1e293b;
  font-size: 52rpx;
  line-height: 1.25;
  font-weight: 700;
}

.my-plan-hero__sub {
  display: block;
  margin-top: 10rpx;
  color: #334155;
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 500;
}

.progress-card,
.info-card,
.day-card {
  margin-top: 16rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.progress-card {
  padding: 20rpx 20rpx 0;
}

.progress-card__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.progress-top-row {
  display: flex;
  align-items: center;
}

.progress-top-row__label {
  color: #1e293b;
  font-size: 30rpx;
  font-weight: 700;
}

.progress-top-row__meta {
  margin-left: 8rpx;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1;
}

.progress-top-row__num {
  font-size: 36rpx;
  font-weight: 700;
}

.progress-status {
  margin-top: 14rpx;
  display: inline-block;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 12rpx;
  background: #131313;
  color: #cdff71;
  font-size: 24rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.progress-illustration {
  width: 160rpx;
  height: 120rpx;
  position: relative;
  flex-shrink: 0;
  margin-top: -6rpx;
}

.progress-illustration__img {
  width: 160rpx;
  height: 120rpx;
  display: block;
}

.progress-illustration__shadow {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 10rpx;
  height: 24rpx;
}

.progress-seekbar {
  margin-top: 8rpx;
  width: 380rpx;
}

.hydration-track {
  position: relative;
  width: 100%;
  height: 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.45);
}

.hydration-fill {
  height: 16rpx;
  background: linear-gradient(90deg, #87fb9b 0%, #1efad5 34.03%, #2cebff 70.86%, #b0ff2f 100%);
  border-radius: 16rpx;
}

.hydration-thumb {
  position: absolute;
  top: 50%;
  width: 20rpx;
  height: 20rpx;
  background: linear-gradient(180deg, #4effe2 0%, #cef94c 100%);
  box-shadow: 0rpx 0rpx 20rpx 2rpx rgba(0, 132, 53, 0.15);
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
  transform: translate(-50%, -50%);
}

.reminder-strip {
  margin-top: 16rpx;
  margin-left: -20rpx;
  margin-right: -20rpx;
  min-height: 64rpx;
  padding: 12rpx 20rpx;
  border-radius: 0 0 24rpx 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(252, 249, 235, 0.7);
  color: #634703;
  font-size: 24rpx;
  line-height: 1.45;
  box-sizing: border-box;
}

.info-card {
  padding: 22rpx 24rpx;
}

.info-card__title {
  display: block;
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.info-card__line {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.info-card__line-label {
  color: #64748b;
  font-size: 30rpx;
  line-height: 1.45;
}

.info-card__line-value {
  max-width: 420rpx;
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.45;
  text-align: right;
  font-weight: 500;
}

.day-card {
  padding: 22rpx 20rpx 20rpx;
}

.day-card__tag-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.day-card__tag {
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 22rpx 0 24rpx 0;
  background: linear-gradient(127deg, #f3e6be 0%, #e8dba7 100%);
  color: #634703;
  font-size: 28rpx;
  line-height: 52rpx;
  font-weight: 700;
}

.day-card__link {
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1;
}

.day-card__head {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.day-card__title {
  color: #1e293b;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
}

.day-card__status {
  height: 40rpx;
  border-radius: 12rpx;
  padding: 0 16rpx;
  background: #131313;
  color: #cdff71;
  font-size: 24rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.recipe-list {
  margin-top: 16rpx;
}

.recipe-item {
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
  padding: 14rpx;
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
}

.recipe-item + .recipe-item {
  margin-top: 14rpx;
}

.recipe-item__cover {
  width: 168rpx;
  height: 126rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.recipe-item__body {
  margin-left: 16rpx;
  flex: 1;
}

.recipe-item__name {
  display: block;
  color: #1e293b;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
}

.recipe-item__tags {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
}

.recipe-item__tag {
  height: 36rpx;
  border-radius: 999rpx;
  padding: 0 12rpx;
  background: rgba(0, 201, 80, 0.14);
  color: #08a74a;
  font-size: 24rpx;
  line-height: 36rpx;
  margin-right: 8rpx;
  margin-bottom: 6rpx;
}

.recipe-item__meta {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recipe-item__meal {
  display: inline-flex;
  align-items: center;
  padding: 0 10rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: rgba(0, 201, 80, 0.14);
  color: #08a74a;
  font-size: 24rpx;
  line-height: 36rpx;
}

.recipe-item__meal-icon {
  width: 20rpx;
  height: 20rpx;
  margin-right: 6rpx;
}

.recipe-item__price {
  color: #e63946;
  font-size: 24rpx;
  line-height: 1;
}

.recipe-item__price-num {
  font-size: 46rpx;
  font-weight: 700;
  margin: 0 4rpx;
}

.recipe-item__side {
  margin-left: 12rpx;
  width: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recipe-item__check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #b8c5d4;
  box-sizing: border-box;
  color: #fff;
  font-size: 22rpx;
  line-height: 34rpx;
  text-align: center;
}

.recipe-item__check--active {
  border-color: #16c95b;
  background: #16c95b;
}

.recipe-item__plus {
  margin-top: 22rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #49cd74;
  color: #ffffff;
  font-size: 36rpx;
  line-height: 36rpx;
  text-align: center;
}

.finish-btn {
  margin-top: 18rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: rgba(182, 235, 205, 0.85);
  color: #0a8a3f;
  font-size: 36rpx;
  line-height: 68rpx;
  font-weight: 700;
  text-align: center;
}

.finish-indicator {
  width: 110rpx;
  height: 6rpx;
  border-radius: 999rpx;
  margin: 16rpx auto 0;
  background: linear-gradient(90deg, #27d172 0%, #d9efe3 100%);
}

.scroll-spacer {
  height: 170rpx;
}

.my-plan-action-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  padding: 16rpx 0 0;
  background: linear-gradient(180deg, rgba(243, 244, 248, 0) 0%, rgba(243, 244, 248, 0.9) 48%, rgba(243, 244, 248, 1) 100%);
}

.my-plan-action-dock__inner {
  width: 638rpx;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
}

.btn-row__btn {
  width: 314rpx;
  height: 74rpx;
  border-radius: 24rpx;
  text-align: center;
  line-height: 74rpx;
  font-size: 38rpx;
}

.btn-row__btn--primary {
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
  font-weight: 700;
}

.btn-row__btn--ghost {
  border: 2rpx solid #dbe3ec;
  background: rgba(226, 245, 239, 0.76);
  color: #1e293b;
  font-weight: 600;
}
