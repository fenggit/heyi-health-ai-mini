.home-page {
  background: transparent;
}

.home-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.home-hero {
  padding-left: 20rpx;
  padding-right: 20rpx;
  padding-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.hero-main-wrap {
  width: 710rpx;
  height: 230rpx;
  margin: 0 auto;
  overflow: hidden;
}

.hero-main {
  width: 710rpx;
  height: 230rpx;
  display: block;
}

.home-content {
  width: 718rpx;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.activity-card {
  position: relative;
  overflow: hidden;
  padding-bottom: 0;
}

.activity-swiper {
  height: 188rpx;
}

.activity-slide {
  width: 100%;
  height: 100%;
}

.activity-banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

.activity-dots {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 12rpx;
  z-index: 2;
  display: flex;
  justify-content: center;
}

.activity-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.45);
}

.activity-dot + .activity-dot {
  margin-left: 10rpx;
}

.activity-dot--active {
  width: 28rpx;
  background: #ffffff;
}

.health-card {
  margin-top: 18rpx;
  padding: 24rpx;
  background: url("../../assets/home-body-heath.png") no-repeat center;
  background-size: 100% 100%;
  overflow: hidden;
}

.health-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.health-title-block {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
}

.health-title-dec {
  width: 88rpx;
  margin-top: 8rpx;
  margin-left: 2rpx;
}

.health-status-pill {
  width: 116rpx;
  height: 48rpx;
  border-radius: 24rpx 0rpx 0rpx 24rpx;
  background: linear-gradient(152deg, #4effe2 0%, #cef94c 100%);
  color: #1e5540;
  font-size: 24rpx;
  line-height: 48rpx;
  text-align: center;
  font-weight: 700;
}

.health-metrics {
  display: flex;
  margin-top: 20rpx;
}

.health-metric {
  flex: 1;
  border-radius: 18rpx;
  background: #f4f8f6;
  padding: 16rpx 10rpx 12rpx;
  text-align: center;
}

.health-metric + .health-metric {
  margin-left: 12rpx;
}

.health-label {
  display: inline-flex;
  align-items: center;
  color: #659277;
  font-size: 20rpx;
  font-weight: 600;
}

.health-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.health-value {
  display: block;
  margin-top: 12rpx;
  color: #2c3d4f;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
}

.hydration {
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: #f1f6f2;
  padding: 18rpx 20rpx;
}

.hydration-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hydration-value {
  color: #4e6157;
  font-size: 24rpx;
  font-weight: 700;
}

.hydration-track {
  display: flex;
  margin-top: 14rpx;
}

.hydration-segment {
  flex: 1;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(132, 217, 154, 0.22);
}

.hydration-segment + .hydration-segment {
  margin-left: 6rpx;
}

.hydration-segment--active {
  background: linear-gradient(90deg, #74eb9b 0%, #cbe95a 100%);
}

.shortcut-grid {
  display: flex;
  margin-top: 18rpx;
}

.shortcut-card {
  position: relative;
  flex: 1;
  min-height: 146rpx;
  border-radius: 24rpx;
  padding: 20rpx;
  overflow: hidden;
}

.shortcut-card + .shortcut-card {
  margin-left: 14rpx;
}

.shortcut-card--robot {
  background: linear-gradient(180deg, #ebf9f0 0%, #e7f4eb 100%);
}

.shortcut-card--bubble {
  background: linear-gradient(180deg, #eef6fb 0%, #eff4f7 100%);
}

.shortcut-copy {
  position: relative;
  z-index: 2;
}

.shortcut-title {
  display: block;
  color: #2d4155;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 700;
}

.shortcut-description {
  display: block;
  margin-top: 8rpx;
  color: #8a97a3;
  font-size: 21rpx;
  line-height: 1.4;
}

.shortcut-icon {
  position: absolute;
  right: 20rpx;
  bottom: 14rpx;
  width: 56rpx;
  height: 48rpx;
}

.shortcut-bubbles {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
}

.shortcut-bubble {
  border-radius: 50%;
  background: rgba(141, 212, 237, 0.35);
}

.shortcut-bubble--lg {
  width: 52rpx;
  height: 52rpx;
}

.shortcut-bubble--md {
  width: 34rpx;
  height: 34rpx;
  margin: 6rpx 0 0 8rpx;
}

.shortcut-bubble--sm {
  width: 20rpx;
  height: 20rpx;
  margin: 6rpx 0 0 22rpx;
}

.section-block {
  margin-top: 20rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-action {
  color: #2aa65f;
  font-size: 24rpx;
  font-weight: 600;
}

.recommendation-card {
  margin-top: 14rpx;
  padding: 22rpx;
}

.recommendation-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.recommendation-name {
  color: #263548;
  font-size: 30rpx;
  font-weight: 700;
}

.recommendation-tags {
  display: flex;
}

.recommendation-tag {
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(102, 216, 145, 0.16);
  color: #1f8b56;
  font-size: 20rpx;
  line-height: 40rpx;
}

.recommendation-tag + .recommendation-tag {
  margin-left: 8rpx;
}

.recommendation-description {
  display: block;
  margin-top: 12rpx;
  color: #5f6f80;
  font-size: 23rpx;
  line-height: 1.55;
}

.tips-card {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
  padding: 22rpx;
}

.tips-head {
  display: flex;
  align-items: center;
  width: 270rpx;
  height: 64rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  background: linear-gradient(127deg, #4effe2 0%, #cef94c 100%);
  border-radius: 22rpx 0rpx 24rpx 0rpx;
}

.tips-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
}

.tips-title {
  color: #2a3c35;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.tips-content {
  display: block;
  margin-top: 10rpx;
  color: #5b6a79;
  font-size: 23rpx;
  line-height: 1.55;
}
