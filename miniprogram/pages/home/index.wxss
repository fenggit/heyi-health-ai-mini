.home-page {
  background: transparent;
}

.home-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.home-hero {
  padding-left: 20rpx;
  padding-right: 20rpx;
  padding-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.hero-main-wrap {
  width: 710rpx;
  height: 230rpx;
  margin: 0 auto;
  overflow: hidden;
}

.hero-main {
  width: 710rpx;
  height: 230rpx;
  display: block;
}

.home-content {
  width: 702rpx;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.home-content .card-panel {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: none;
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.home-content .section-title {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.home-content .section-subtitle {
  color: #334155;
  font-size: 24rpx;
  line-height: 34rpx;
}

.activity-card {
  position: relative;
  overflow: hidden;
  padding-bottom: 0;
}

.activity-swiper {
  height: 240rpx;
}

.activity-slide {
  width: 100%;
  height: 100%;
}

.activity-banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

.activity-dots {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 10rpx;
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
}

.activity-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.45);
}

.activity-dot + .activity-dot {
  margin-left: 8rpx;
}

.activity-dot--active {
  width: 20rpx;
  background: #ffffff;
}

.home-content .health-card {
  margin-top: 16rpx;
  padding: 30rpx 24rpx 24rpx;
  background: url("../../assets/home-body-heath.png") no-repeat center;
  background-size: 100% 100%;
  overflow: hidden;
}

.health-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.health-title-block {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
}

.health-title-dec {
  width: 88rpx;
  margin-top: 8rpx;
  margin-left: 0;
}

.health-status-pill {
  width: 116rpx;
  height: 48rpx;
  border-radius: 24rpx 0rpx 0rpx 24rpx;
  background: linear-gradient(152deg, #4effe2 0%, #cef94c 100%);
  color: #1e5540;
  font-size: 24rpx;
  line-height: 48rpx;
  text-align: center;
  font-weight: 700;
}

.health-metrics {
  display: flex;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid #e4ebea;
}

.health-metric {
  flex: 1;
  display: flex;
  flex-direction: column-reverse;
  align-items: center;
  text-align: center;
}

.health-metric + .health-metric {
  margin-left: 10rpx;
}

.health-label {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 112rpx;
  height: 44rpx;
  border-radius: 12rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  color: #008435;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(0, 201, 80, 0.08);
}

.health-icon {
  width: 22rpx;
  height: 22rpx;
  margin-right: 6rpx;
}

.health-value {
  display: block;
  margin-bottom: 18rpx;
  color: #1e293b;
  font-size: 36rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.hydration {
  margin-top: 18rpx;
  padding: 0;
  background: transparent;
}

.hydration-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hydration-value {
  color: #475569;
  font-size: 24rpx;
  font-weight: 700;
}

.hydration-track {
  display: flex;
  margin-top: 12rpx;
}

.hydration-segment {
  flex: 1;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(0, 201, 80, 0.16);
}

.hydration-segment + .hydration-segment {
  margin-left: 4rpx;
}

.hydration-segment--active {
  background: linear-gradient(90deg, #74eb9b 0%, #cbe95a 100%);
}

.shortcut-grid {
  display: flex;
  margin-top: 16rpx;
}

.shortcut-card {
  position: relative;
  flex: 1;
  min-height: 148rpx;
  border-radius: 24rpx;
  padding: 22rpx 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  overflow: hidden;
  box-sizing: border-box;
}

.shortcut-card + .shortcut-card {
  margin-left: 18rpx;
}

.shortcut-card--robot {
  background: linear-gradient(180deg, #ebf9f0 0%, #e7f4eb 100%);
}

.shortcut-card--bubble {
  background: linear-gradient(180deg, #eef6fb 0%, #eff4f7 100%);
}

.shortcut-copy {
  position: relative;
  z-index: 2;
}

.shortcut-title {
  display: block;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
}

.shortcut-description {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.4;
}

.shortcut-icon {
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  width: 56rpx;
  height: 56rpx;
}

.shortcut-bubbles {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
}

.shortcut-bubble {
  border-radius: 50%;
  background: rgba(141, 212, 237, 0.35);
}

.shortcut-bubble--lg {
  width: 52rpx;
  height: 52rpx;
}

.shortcut-bubble--md {
  width: 34rpx;
  height: 34rpx;
  margin: 6rpx 0 0 8rpx;
}

.shortcut-bubble--sm {
  width: 20rpx;
  height: 20rpx;
  margin: 6rpx 0 0 22rpx;
}

.section-block {
  margin-top: 16rpx;
  padding: 20rpx 16rpx 18rpx;
  overflow: hidden;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx;
}

.section-action {
  color: #94a3b8;
  font-size: 24rpx;
  font-weight: 400;
}

.recommendation-image {
  display: block;
  width: 100%;
  height: 190rpx;
  margin-top: 16rpx;
  border-radius: 16rpx;
}

.recommendation-card {
  margin-top: 14rpx;
  padding: 0 8rpx 6rpx;
}

.recommendation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recommendation-name {
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.recommendation-tags {
  display: flex;
}

.recommendation-tag {
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  background: rgba(0, 201, 80, 0.1);
  color: #008435;
  font-size: 24rpx;
  line-height: 40rpx;
}

.recommendation-tag + .recommendation-tag {
  margin-left: 8rpx;
}

.recommendation-description {
  display: block;
  margin-top: 10rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 42rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.home-content .tips-card {
  margin-top: 16rpx;
  margin-bottom: 0;
  padding: 2rpx 16rpx 22rpx 2rpx;
  background: rgba(223, 249, 232, 0.7);
}

.tips-head {
  display: flex;
  align-items: center;
  width: 270rpx;
  height: 64rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  background: linear-gradient(127deg, #4effe2 0%, #cef94c 100%);
  border-radius: 22rpx 0rpx 24rpx 0rpx;
}

.tips-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
}

.tips-title {
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.tips-content {
  display: block;
  margin-top: 14rpx;
  padding-left: 30rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 42rpx;
}
