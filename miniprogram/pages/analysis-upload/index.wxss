.upload-page {
  background: transparent;
}

.upload-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.upload-wrap {
  position: relative;
  z-index: 1;
}

.upload-page .card-panel {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
  box-shadow: none;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.upload-wrap {
  width: 702rpx;
  margin: 6rpx auto 0;
  padding-bottom: 32rpx;
}

.upload-head {
  position: relative;
  padding-top: 8rpx;
  min-height: 88rpx;
}

.upload-head__subtitle {
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 500;
}

.upload-head__title {
  margin-top: 8rpx;
  color: #1e293b;
  font-size: 40rpx;
  line-height: 1.28;
  font-weight: 700;
}

.upload-head__tag {
  position: absolute;
  right: 0;
  top: 40rpx;
  min-width: 128rpx;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 12rpx;
  background: #cdff71;
  color: #1e293b;
  font-size: 22rpx;
  line-height: 40rpx;
  text-align: center;
  font-weight: 700;
  box-sizing: border-box;
}

.upload-step-card {
  margin-top: 16rpx;
  padding: 16rpx 24rpx 18rpx;
  background: rgba(255, 255, 255, 0.7);
}

.upload-step-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.upload-step-left {
  display: flex;
  align-items: flex-start;
}

.upload-step-label {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
}

.upload-step-title-wrap {
  margin-left: 6rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.upload-step-title {
  color: #1e293b;
  font-size: 26rpx;
  line-height: 1.35;
  font-weight: 500;
}

.upload-step-title__dec {
  width: 96rpx;
  margin-top: 2rpx;
}

.upload-step-count {
  margin-top: -2rpx;
  color: #1e293b;
  line-height: 1.2;
}

.upload-step-count__num {
  font-size: 36rpx;
  font-weight: 700;
}

.upload-step-count__rest {
  font-size: 22rpx;
  font-weight: 500;
}

.upload-progress-track {
  position: relative;
  margin-top: 16rpx;
  height: 12rpx;
  border-radius: 10rpx;
  background: rgba(0, 201, 80, 0.14);
}

.upload-progress-fill {
  width: 100%;
  height: 12rpx;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #00c950 0%, #77e258 100%);
}

.upload-progress-dot {
  position: absolute;
  right: -2rpx;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #f8ffef;
  border: 2rpx solid #6fe066;
  transform: translateY(-50%);
  box-sizing: border-box;
}

.upload-main-card {
  margin-top: 14rpx;
  padding: 20rpx 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.7);
}

.upload-intro {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.6;
}

.upload-card {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: rgba(248, 250, 252, 0.72);
}

.upload-card__title {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
}

.upload-photo {
  margin-top: 14rpx;
  width: 100%;
  height: 252rpx;
  border-radius: 18rpx;
  border: 2rpx dashed #cbd5e1;
  overflow: hidden;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.85);
}

.upload-photo__img {
  width: 100%;
  height: 100%;
}

.upload-photo__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
}

.upload-photo__plus {
  font-size: 54rpx;
  line-height: 1;
  font-weight: 500;
}

.upload-photo__label {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
}

.upload-actions {
  margin-top: 14rpx;
  display: flex;
}

.upload-action {
  flex: 1;
  height: 68rpx;
  border-radius: 20rpx;
  text-align: center;
  line-height: 68rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.upload-action + .upload-action {
  margin-left: 12rpx;
}

.upload-action--primary {
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
}

.upload-action--ghost {
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.72);
  color: #475569;
}

.upload-tip {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.5;
}

.upload-tip__label {
  font-weight: 700;
}

.upload-disclaimer-wrap {
  margin-top: 18rpx;
  padding: 10rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: rgba(252, 249, 235, 0.38);
}

.upload-disclaimer {
  color: #634703;
  font-size: 22rpx;
  line-height: 1.45;
}

.upload-bottom-actions {
  margin-top: 18rpx;
  display: flex;
}

.upload-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 24rpx;
  text-align: center;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.upload-btn + .upload-btn {
  margin-left: 18rpx;
}

.upload-btn--ghost {
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.75);
  color: #1e293b;
}

.upload-btn--primary {
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
}

.upload-btn--disabled {
  opacity: 0.55;
}

.upload-link {
  margin-top: 14rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.4;
  text-decoration: underline;
}
