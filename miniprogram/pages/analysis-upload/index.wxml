<view class="upload-page design-page">
  <image class="upload-page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <view class="mini-nav__title">趣味分析</view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="upload-wrap">
    <view class="upload-head">
      <view class="upload-head__title">{{title}}</view>
      <view class="upload-head__subtitle">{{subTitle}}</view>
      <view class="upload-head__tag">趣味分析</view>
    </view>

    <view class="card-panel upload-step-card">
      <image class="upload-step-card__bg" src="/assets/analysis/page03_wrap@2x.png" mode="scaleToFill" />
      <view class="upload-step-row">
        <text class="upload-step-label">步骤二：</text>
        <text class="upload-step-title">视觉分析</text>
      </view>
      <view class="upload-step-intro">
        <view class="upload-step-intro__line">
          <text class="upload-step-intro__label">AI 视觉分析：</text>
          <text class="upload-step-intro__text">{{intro}}</text>
        </view>
        <view class="upload-step-intro__notice">{{introNotice}}</view>
      </view>
    </view>

    <view class="card-panel upload-card">
      <view class="upload-card__head">
        <view class="upload-card__icon-wrap">
          <image class="upload-card__icon" src="/assets/analysis/camera_icon@2x.png" mode="aspectFit" />
        </view>
        <view class="upload-card__meta">
          <view class="upload-card__title">舌苔拍照</view>
          <view class="upload-card__desc">{{tongueDesc}}</view>
        </view>
      </view>
      <view wx:if="{{tongueImage}}" class="upload-photo-preview">
        <image class="upload-photo-preview__img" src="{{tongueImage}}" mode="aspectFill" />
      </view>
      <view class="upload-actions">
        <view class="upload-action" bindtap="chooseTongueCamera">
          <view class="upload-action__content">
            <image class="upload-action-icon" src="/assets/analysis/image_icon@2x.png" mode="aspectFit" />
            <text class="upload-action__text">拍摄舌苔照片</text>
          </view>
        </view>
        <view class="upload-action" bindtap="chooseTongueAlbum">
          <view class="upload-action__content">
            <image class="upload-action-icon" src="/assets/analysis/upload_icon@2x.png" mode="aspectFit" />
            <text class="upload-action__text">从相册获取</text>
          </view>
        </view>
      </view>
      <view class="upload-tip-divider"></view>
      <view class="upload-tip">
        <text class="upload-tip__label">拍摄提示：</text>
        <text>{{tongueTip}}</text>
      </view>
    </view>

    <view class="card-panel upload-card">
      <view class="upload-card__head">
        <view class="upload-card__icon-wrap">
          <image class="upload-card__icon" src="/assets/analysis/camera_icon@2x.png" mode="aspectFit" />
        </view>
        <view class="upload-card__meta">
          <view class="upload-card__title">面色拍照</view>
          <view class="upload-card__desc">{{faceDesc}}</view>
        </view>
      </view>
      <view wx:if="{{faceImage}}" class="upload-photo-preview">
        <image class="upload-photo-preview__img" src="{{faceImage}}" mode="aspectFill" />
      </view>
      <view class="upload-actions">
        <view class="upload-action" bindtap="chooseFaceCamera">
          <view class="upload-action__content">
            <image class="upload-action-icon" src="/assets/analysis/image_icon@2x.png" mode="aspectFit" />
            <text class="upload-action__text">拍摄面部照片</text>
          </view>
        </view>
        <view class="upload-action" bindtap="chooseFaceAlbum">
          <view class="upload-action__content">
            <image class="upload-action-icon" src="/assets/analysis/upload_icon@2x.png" mode="aspectFit" />
            <text class="upload-action__text">从相册获取</text>
          </view>
        </view>
      </view>
      <view class="upload-tip-divider"></view>
      <view class="upload-tip">
        <text class="upload-tip__label">拍摄提示：</text>
        <text>{{faceTip}}</text>
      </view>
    </view>

    <view class="upload-btn upload-btn--primary" bindtap="finish">完成分析</view>
    <view class="upload-link" bindtap="skipAndFinish">跳过拍照，直接生成报告</view>
  </view>
</view>
