<view class="analysis-page design-page">
  <image class="analysis-page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="analysis-wrap">
    <view class="analysis-head">
      <view class="analysis-head__title">{{introSubTitle}}</view>
      <view class="analysis-head__subtitle">{{introTitle}}</view>
    </view>

    <view class="card-panel analysis-declaration-card">
      <view class="analysis-label-pill">
        <image class="analysis-label-pill__icon" src="/assets/analysis/star.png" mode="aspectFit" />
        <text class="analysis-label-pill__text">重要声明</text>
      </view>
      <view class="analysis-content">{{declaration}}</view>

      <view class="card-panel analysis-ai-card">
        <view class="analysis-ai-card__title">{{aiContentTitle}}</view>
        <view class="analysis-ai-card__text">{{aiContent}}</view>
      </view>
    </view>

    <view class="card-panel analysis-main-card">
      <view class="analysis-section-head">
        <title-view text="我们提供的服务" dec-src="/assets/analysis/title_dec.png" />
      </view>

      <block wx:for="{{extras}}" wx:key="*this">
        <view class="analysis-service-item">
          <image class="analysis-service-item__icon" src="/assets/analysis/check_green.png" mode="aspectFit" />
          <text>{{item}}</text>
        </view>
      </block>

      <view class="analysis-section-head analysis-section-head--limit">
        <title-view text="使用限制" dec-src="/assets/analysis/title_dec.png" />
      </view>

      <block wx:for="{{bullets}}" wx:key="*this">
        <view class="analysis-limit-item">· {{item}}</view>
      </block>

      <view class="analysis-divider"></view>

      <view class="analysis-agree" bindtap="toggleAgree">
        <view class="analysis-check {{agreed ? 'analysis-check--active' : ''}}">
          <text wx:if="{{agreed}}" class="analysis-check__tick">✓</text>
        </view>
        <view class="analysis-agree__text">{{agreementText}}</view>
      </view>

      <view class="analysis-btn analysis-btn--primary" bindtap="startQuiz">开始测评</view>
      <view class="analysis-btn-link" bindtap="backHome">返回首页</view>
    </view>
  </view>
</view>
