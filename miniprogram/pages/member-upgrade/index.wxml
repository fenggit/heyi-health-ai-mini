<view class="member-page design-page page-with-nav">
  <image class="page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <view class="mini-nav__title">{{navTitle}}</view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="page-wrap page-wrap--no-title">
    <view class="glass-card member-top-card">
      <view class="member-top-title">{{pageTitle}}</view>
      <scroll-view class="member-plan-scroll" scroll-x="true" show-scrollbar="false">
        <view class="member-plan-list">
          <block wx:for="{{plans}}" wx:key="id">
            <view
              class="member-plan-item {{selectedPlanId === item.id ? 'member-plan-item--active' : ''}} {{item.dark ? 'member-plan-item--dark' : ''}}"
              data-id="{{item.id}}"
              bindtap="selectPlan"
            >
              <view class="member-plan-item__title">{{item.title}}</view>
              <view class="member-plan-item__price-wrap">
                <text class="member-plan-item__currency">¥</text>
                <text class="member-plan-item__price">{{item.price}}</text>
                <text class="member-plan-item__unit">{{item.unit}}</text>
              </view>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>

    <view class="glass-card member-right-card">
      <title-view text="会员权益" />
      <block wx:for="{{benefits}}" wx:key="*this">
        <view class="member-benefit-row">✔ {{item}}</view>
      </block>

      <view class="member-section-title--gap">
        <title-view text="会员专属福利" />
      </view>
      <view class="member-welfare-grid">
        <block wx:for="{{welfares}}" wx:key="label">
          <view class="member-welfare-item">
            <image class="member-welfare-item__icon" src="{{item.icon}}" mode="aspectFit" />
            <view>{{item.label}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="glass-card member-faq-card">
      <title-view text="常见问题" />
      <block wx:for="{{faqs}}" wx:key="id">
        <view class="member-faq-item">
          <view class="member-faq-item__q">{{item.q}}</view>
          <view class="member-faq-item__a">{{item.a}}</view>
        </view>
      </block>
    </view>

    <view class="member-action-row">
      <view class="member-action member-action--cancel" bindtap="cancel">取消</view>
      <view class="member-action member-action--open" bindtap="openNow">立即开通</view>
    </view>
  </view>
</view>
