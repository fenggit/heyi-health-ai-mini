@import "../profile-sub/common.wxss";

.member-top-card {
  margin-top: 6rpx;
  padding: 18rpx 0 18rpx;
  background: linear-gradient(115deg, rgba(69, 231, 207, 0.86) 0%, rgba(199, 236, 73, 0.85) 100%);
  border: none;
}

.member-top-title {
  text-align: center;
  color: #1e293b;
  font-size: 42rpx;
  font-weight: 700;
}

.member-plan-scroll {
  margin-top: 16rpx;
  width: 100%;
  white-space: nowrap;
}

.member-plan-list {
  display: inline-flex;
  padding: 0 18rpx;
  gap: 12rpx;
}

.member-plan-item {
  width: 210rpx;
  height: 152rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  padding: 12rpx;
  box-sizing: border-box;
}

.member-plan-item--active {
  box-shadow: inset 0 0 0 3rpx #44cf88;
}

.member-plan-item--dark {
  background: #121212;
}

.member-plan-item__title {
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #131313;
}

.member-plan-item--dark .member-plan-item__title {
  color: #cdff71;
}

.member-plan-item__price-wrap {
  margin-top: 24rpx;
  text-align: center;
  color: #131313;
}

.member-plan-item__currency {
  font-size: 30rpx;
}

.member-plan-item__price {
  font-size: 56rpx;
  font-weight: 700;
}

.member-plan-item__unit {
  font-size: 26rpx;
}

.member-right-card,
.member-faq-card {
  padding: 20rpx 24rpx;
}

.member-right-card {
  margin-top: 14rpx;
}

.member-section-title--gap {
  margin-top: 20rpx;
}

.member-benefit-row {
  margin-top: 12rpx;
  color: #334155;
  font-size: 34rpx;
}

.member-welfare-grid {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.member-welfare-item {
  width: 318rpx;
  min-height: 90rpx;
  border-radius: 16rpx;
  background: rgba(248, 250, 252, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #334155;
  font-size: 30rpx;
  font-weight: 600;
}

.member-welfare-item__icon {
  width: 26rpx;
  height: 26rpx;
}

.member-faq-card {
  margin-top: 14rpx;
}

.member-faq-item {
  margin-top: 12rpx;
}

.member-faq-item__q,
.member-faq-item__a {
  color: #475569;
  font-size: 34rpx;
  line-height: 1.5;
}

.member-action-row {
  position: sticky;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.member-action {
  flex: 1;
  height: 78rpx;
  border-radius: 20rpx;
  text-align: center;
  line-height: 78rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.member-action--cancel {
  background: rgba(241, 245, 249, 0.92);
  color: #64748b;
}

.member-action--open {
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
}
