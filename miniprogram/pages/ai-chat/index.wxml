<view class="analysis-page design-page">
  <image class="analysis-page-bg" src="/assets/analysis/chat/bg_ai.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <text class="analysis-nav__title">AI</text>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="analysis-main" style="height: calc(100vh - {{topInset}}px - {{inputDockHeight}}px);">
    <view class="analysis-head">
      <text class="analysis-head__title">{{title}}</text>
      <view class="analysis-head__row">
        <text class="analysis-head__sub">{{subTitle}}</text>
        <image class="analysis-head__hello" src="/assets/analysis/chat/hash_tag.png" mode="widthFix" />
      </view>
    </view>

    <view class="card-panel analysis-intro-card">
      <view class="analysis-intro-card__head">
        <text class="analysis-intro-card__title">我可以帮你：</text>
      </view>
      <block wx:for="{{capabilities}}" wx:key="*this">
        <view class="analysis-intro-card__item">· {{item}}</view>
      </block>
      <view class="analysis-intro-card__notice">
        <image class="analysis-intro-card__notice-icon" src="/assets/analysis/chat/prompt_icon.png" mode="aspectFit" />
        <text class="analysis-intro-card__notice-text">{{noticeText}}</text>
      </view>
    </view>

    <view class="analysis-quick-grid">
      <block wx:for="{{quickActions}}" wx:key="id">
        <view class="analysis-quick-item" data-path="{{item.path}}" data-route-type="{{item.routeType}}" bindtap="tapQuickAction">
          <view class="analysis-quick-item__hash">#</view>
          <text class="analysis-quick-item__text">{{item.label}}</text>
        </view>
      </block>
    </view>

    <view class="analysis-chat-wrap">
      <scroll-view
        class="analysis-chat-scroll"
        scroll-y="true"
        scroll-with-animation="true"
        scroll-top="{{chatScrollTop}}"
      >
        <view class="analysis-chat-list">
          <block wx:for="{{messages}}" wx:key="id">
            <view id="msg-{{item.id}}" class="analysis-chat-row {{item.role === 'user' ? 'analysis-chat-row--user' : ''}}">
              <view
                class="analysis-chat-bubble {{item.role === 'user' ? 'analysis-chat-bubble--user' : 'analysis-chat-bubble--assistant'}} {{item.leftIcon ? 'analysis-chat-bubble--with-icon' : ''}}"
              >
                <image
                  wx:if="{{item.leftIcon}}"
                  class="analysis-chat-bubble__icon"
                  src="{{item.leftIcon}}"
                  mode="aspectFit"
                />
                <text class="analysis-chat-bubble__text">{{item.text}}</text>
              </view>
              <text class="analysis-chat-time">{{item.time}}</text>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="analysis-input-dock" style="padding-bottom: calc(16rpx + {{safeBottom}}px);">
    <view class="analysis-input-shell">
      <view wx:if="{{inputMode === 'text'}}" class="analysis-input-row" bindtap="focusInput">
        <view class="analysis-input-icon-wrap analysis-input-icon-wrap--left-box" catchtap="switchToVoice">
          <image class="analysis-input-icon analysis-input-icon--large" src="/assets/analysis/chat/mic_icon.png" mode="aspectFit" />
        </view>
        <input
          class="analysis-text-input"
          value="{{draftText}}"
          focus="{{inputFocus}}"
          placeholder="输入消息或者使用语音..."
          placeholder-class="analysis-text-input__placeholder"
          bindinput="onInputChange"
          bindconfirm="sendText"
          bindblur="onInputBlur"
          confirm-type="send"
        />
      </view>

      <view wx:else class="analysis-voice-row">
        <view class="analysis-input-icon-wrap analysis-input-icon-wrap--left-box" bindtap="switchToText">
          <image class="analysis-input-icon analysis-input-icon--large" src="/assets/analysis/chat/keyboard_icon.png" mode="aspectFit" />
        </view>
        <view
          class="analysis-voice-hold {{voiceHolding ? 'analysis-voice-hold--active' : ''}}"
          bindtouchstart="onVoiceHoldStart"
          bindtouchmove="onVoiceHoldMove"
          bindtouchend="onVoiceHoldEnd"
          bindtouchcancel="onVoiceHoldCancel"
        >
          按住说话
        </view>
      </view>
    </view>

    <view wx:if="{{voiceHintVisible}}" class="analysis-record-overlay">
      <image
        class="analysis-record-overlay__bg"
        src="{{voiceHintCancel ? '/assets/analysis/chat/voice_cancel.png' : '/assets/analysis/chat/voice_confirm.png'}}"
        mode="scaleToFill"
      />
      <view class="analysis-record-overlay__content">
        <text class="analysis-record-overlay__title">{{voiceHintCancel ? "松手取消" : "松手发送，上移取消"}}</text>
        <view class="analysis-record-overlay__wave">
          <block wx:for="{{waveBars}}" wx:key="index">
            <view
              class="analysis-record-overlay__bar"
              style="height: {{item}}rpx; animation-delay: {{index * 0.05}}s;"
            ></view>
          </block>
        </view>
      </view>
    </view>
  </view>
</view>
