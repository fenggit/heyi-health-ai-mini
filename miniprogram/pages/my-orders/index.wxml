<view class="orders-page design-page page-with-nav">
  <image class="page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <view class="mini-nav__title">{{navTitle}}</view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="page-wrap page-wrap--no-title">
    <view class="orders-tabs">
      <block wx:for="{{tabs}}" wx:key="key">
        <view class="orders-tab {{activeTab === item.key ? 'orders-tab--active' : ''}}" data-tab="{{item.key}}" bindtap="selectTab">
          {{item.label}}
        </view>
      </block>
    </view>

    <block wx:for="{{filteredOrders}}" wx:key="id" wx:for-item="order">
      <view class="glass-card order-card">
        <view class="order-card__head">
          <view class="order-id">订单号：{{order.id}}</view>
          <view class="order-status {{order.statusClass}}">{{order.statusText}}</view>
        </view>

        <view class="order-thumb-row">
          <block wx:for="{{order.items}}" wx:key="image" wx:for-item="product">
            <view class="order-thumb-item">
              <image class="order-thumb-item__image" src="{{product.image}}" mode="aspectFill" />
              <view class="order-thumb-item__count">x{{product.count}}</view>
            </view>
          </block>
          <view class="order-thumb-total">共计：{{order.totalCount}} 件</view>
        </view>

        <view class="order-info-row">
          <view class="order-time">下单时间：{{order.createTime}}</view>
          <view class="order-total">合计：<text class="order-total__price">¥{{order.totalPrice}}</text></view>
        </view>

        <view class="order-actions">
          <view class="order-btn order-btn--line" data-id="{{order.id}}" bindtap="viewLogistics">查看物流</view>
          <view class="order-btn order-btn--line" data-id="{{order.id}}" bindtap="viewDetail">订单详情</view>
        </view>
      </view>
    </block>
  </view>
</view>
