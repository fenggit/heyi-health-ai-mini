<view class="about-page design-page page-with-nav">
  <image class="page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <view class="mini-nav__title">{{navTitle}}</view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="page-wrap page-wrap--no-title">
    <view class="glass-card about-brand-card">
      <view class="about-logo">合</view>
      <view class="about-name">{{appName}}</view>
      <view class="about-copy">{{version}}</view>
      <view class="about-copy">{{copyright}}</view>
    </view>

    <view class="glass-card about-content-card">
      <view class="about-section-title">我们的使命</view>
      <view class="about-mission">{{mission}}</view>

      <view class="about-section-title about-section-title--gap">核心价值</view>
      <block wx:for="{{values}}" wx:key="*this">
        <view class="about-bullet">· {{item}}</view>
      </block>

      <view class="about-section-title about-section-title--gap">专业团队</view>
      <view class="about-team-grid">
        <block wx:for="{{teamStats}}" wx:key="label">
          <view class="about-team-item">
            <view class="about-team-item__label">{{item.label}}</view>
            <view class="about-team-item__value">{{item.value}}</view>
          </view>
        </block>
      </view>

      <view class="about-section-title about-section-title--gap">服务成果</view>
      <view class="about-result-grid">
        <block wx:for="{{resultStats}}" wx:key="label">
          <view class="about-result-item">
            <view class="about-result-item__value">{{item.value}}</view>
            <view class="about-result-item__label">{{item.label}}</view>
          </view>
        </block>
      </view>

      <view class="about-section-title about-section-title--gap">联系我们</view>
      <block wx:for="{{contacts}}" wx:key="label">
        <view class="about-contact-row">
          <text class="about-contact-row__label">{{item.label}}</text>
          <text class="about-contact-row__value">{{item.value}}</text>
        </view>
      </block>

      <view class="about-link" bindtap="openAgreement">用户协议</view>
      <view class="about-link" bindtap="openPrivacy">隐私政策</view>

      <view class="about-tip">提示：合一食养不能替代医疗诊断和治疗如有健康问题请及时就医。</view>
    </view>
  </view>
</view>
