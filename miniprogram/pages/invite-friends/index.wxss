@import "../profile-sub/common.wxss";

.invite-page .page-title {
  font-size: 48rpx;
}

.invite-reward-tag {
  margin-top: 10rpx;
  margin-left: auto;
  width: 110rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
  font-size: 24rpx;
  line-height: 44rpx;
  text-align: center;
  font-weight: 700;
}

.invite-main-card {
  margin-top: 10rpx;
  padding: 18rpx;
}

.invite-section-title,
.invite-code-title,
.invite-record-title {
  color: #334155;
  font-size: 28rpx;
  font-weight: 700;
}

.invite-summary-row {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
}

.invite-summary-item {
  flex: 1;
  min-height: 88rpx;
  border-radius: 16rpx;
  background: rgba(241, 245, 249, 0.92);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #334155;
  font-size: 24rpx;
}

.invite-summary-item__value {
  margin-top: 8rpx;
  color: #d97706;
  font-size: 30rpx;
  font-weight: 700;
}

.invite-summary-item__value--purple {
  color: #8b5cf6;
}

.invite-reward-box {
  margin-top: 12rpx;
  border-radius: 14rpx;
  background: #f4efe2;
  padding: 12rpx;
}

.invite-reward-box__title {
  color: #8f6b20;
  font-size: 24rpx;
  font-weight: 700;
}

.invite-reward-row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  color: #4b5563;
  font-size: 24rpx;
}

.invite-reward-row__value {
  color: #d97706;
  font-weight: 600;
}

.invite-code-title {
  margin-top: 14rpx;
}

.invite-code-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.invite-code {
  flex: 1;
  height: 64rpx;
  border-radius: 14rpx;
  background: rgba(241, 245, 249, 0.92);
  padding: 0 16rpx;
  color: #334155;
  font-size: 26rpx;
  line-height: 64rpx;
  font-weight: 600;
}

.invite-copy {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: #19bf55;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 64rpx;
  text-align: center;
}

.invite-share-list {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
}

.invite-share-item {
  flex: 1;
  min-height: 106rpx;
  border-radius: 14rpx;
  background: rgba(241, 245, 249, 0.92);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.invite-share-item__icon-wrap {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-share-item__icon {
  width: 32rpx;
  height: 32rpx;
}

.invite-share-item__name {
  margin-top: 8rpx;
  color: #334155;
  font-size: 24rpx;
}

.invite-record-title {
  margin-top: 14rpx;
}

.invite-record-row {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.invite-record-row__user {
  color: #334155;
  font-size: 24rpx;
}

.invite-record-row__time {
  margin-top: 4rpx;
  color: #94a3b8;
  font-size: 20rpx;
}

.invite-record-row__status {
  color: #19bf55;
  font-size: 24rpx;
  font-weight: 700;
}
