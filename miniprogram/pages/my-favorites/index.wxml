<view class="favorites-page design-page page-with-nav">
  <image class="page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <view class="mini-nav__title">{{navTitle}}</view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="page-wrap page-wrap--no-title">
    <block wx:for="{{list}}" wx:key="id" wx:for-item="favorite">
      <view class="glass-card favorite-card">
        <image class="favorite-cover" src="{{favorite.image}}" mode="aspectFill" />
        <view class="favorite-main">
          <view class="favorite-name">{{favorite.name}}</view>
          <view class="favorite-tags">
            <block wx:for="{{favorite.tags}}" wx:key="*this" wx:for-item="tag">
              <text class="favorite-tag">{{tag}}</text>
            </block>
          </view>
          <view class="favorite-desc">{{favorite.desc}}</view>
          <view class="favorite-divider"></view>
          <view class="favorite-foot">
            <text class="favorite-time">收藏时间：{{favorite.time}}</text>
            <view class="favorite-cancel" data-id="{{favorite.id}}" bindtap="cancelFavorite">取消收藏</view>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
