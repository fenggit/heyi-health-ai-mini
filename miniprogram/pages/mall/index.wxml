<view class="mall-page design-page design-page--with-tab">
  <image class="mall-page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mall-top-gap page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="mall-title">{{mallTitle}}</view>

  <view class="mall-header">
    <view class="mall-location">
      <image class="mall-location__icon" src="/assets/mall/icon-location.png" mode="aspectFit" />
      <text class="mall-location__text">{{city}}</text>
    </view>
    <view class="mall-search card-panel">
      <image class="mall-search__icon" src="/assets/mall/icon-search.png" mode="aspectFit" />
      <input
        class="mall-search__input"
        type="text"
        value="{{searchKeyword}}"
        placeholder="{{searchPlaceholder}}"
        placeholder-style="color: #94a3b8;"
        bindinput="onInputSearch"
      />
    </view>
    <view class="mall-cart card-panel" bindtap="openCart">
      <image class="mall-cart__icon" src="/assets/mall/icon-cart.png" mode="aspectFit" />
      <view class="mall-cart__badge" wx:if="{{cartCount > 0}}">
        <text>{{cartCount > 99 ? '99+' : cartCount}}</text>
      </view>
    </view>
  </view>

  <view class="mall-content">
    <view class="mall-banner card-panel">
      <swiper
        class="mall-banner-swiper"
        current="{{bannerCurrent}}"
        circular
        autoplay
        interval="4200"
        duration="420"
        bindchange="onBannerChange"
      >
        <block wx:for="{{activityBanners}}" wx:key="id">
          <swiper-item>
            <view class="mall-banner-slide">
              <image class="mall-banner-image" src="{{item.image}}" mode="aspectFill" />
            </view>
          </swiper-item>
        </block>
      </swiper>
      <view class="mall-banner-dots" wx:if="{{activityBanners.length > 1}}">
        <block wx:for="{{activityBanners}}" wx:key="id">
          <view class="mall-banner-dot {{index === bannerCurrent ? 'mall-banner-dot--active' : ''}}"></view>
        </block>
      </view>
    </view>

    <view class="mall-tabs">
      <block wx:for="{{categories}}" wx:key="key">
        <view
          class="mall-tab {{index === activeCategory ? 'mall-tab--active' : ''}}"
          data-index="{{index}}"
          data-key="{{item.key}}"
          bindtap="selectCategory"
        >
          <text>{{item.label}}</text>
          <view wx:if="{{index === activeCategory}}" class="mall-tab__dec"></view>
        </view>
      </block>
    </view>

    <view class="mall-grid">
      <block wx:for="{{products}}" wx:key="id">
        <view class="card-panel mall-product" data-id="{{item.id}}" bindtap="openProduct">
          <view wx:if="{{item.badge}}" class="mall-product__badge mall-product__badge--{{item.badgeType ? item.badgeType : 'new'}}">
            {{item.badge}}
          </view>
          <view class="mall-product__thumb-wrap">
            <image class="mall-product__thumb" src="{{item.image}}" mode="aspectFit" />
          </view>
          <view class="mall-product__name">{{item.name}}</view>
          <view class="mall-product__meta">
            <view class="mall-product__score">
              <text class="mall-product__star">★</text>
              <text>{{item.score}}</text>
            </view>
            <text class="mall-product__stock">库存 {{item.stock}}</text>
          </view>
          <view class="mall-product__foot">
            <view class="mall-product__price">
              <text class="mall-product__price-symbol">￥</text>
              <text class="mall-product__price-main">{{item.price}}</text>
              <text class="mall-product__price-unit">{{item.unit}}</text>
            </view>
            <view class="mall-product__add" data-id="{{item.id}}" catchtap="addToCart">+</view>
          </view>
        </view>
      </block>
      <view class="mall-empty" wx:if="{{products.length === 0}}">暂无符合条件的商品</view>
    </view>
  </view>
</view>
