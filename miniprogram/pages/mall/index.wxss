.mall-page {
  background: transparent;
}

.mall-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.mall-top-gap,
.mall-title,
.mall-header,
.mall-content {
  position: relative;
  z-index: 1;
}

.mall-page .card-panel {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: none;
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.mall-title {
  width: 702rpx;
  margin: 0 auto;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.mall-header {
  width: 702rpx;
  margin: 10rpx auto 0;
  display: flex;
  align-items: center;
}

.mall-location {
  display: inline-flex;
  align-items: center;
  margin-right: 12rpx;
}

.mall-location__icon {
  width: 24rpx;
  height: 24rpx;
}

.mall-location__text {
  margin-left: 6rpx;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 500;
}

.mall-search {
  flex: 1;
  height: 64rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
}

.mall-search__icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 10rpx;
  opacity: 0.82;
}

.mall-search__input {
  width: 100%;
  font-size: 24rpx;
  color: #334155;
}

.mall-cart {
  width: 64rpx;
  height: 64rpx;
  margin-left: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mall-cart__icon {
  width: 34rpx;
  height: 34rpx;
}

.mall-content {
  width: 702rpx;
  margin: 18rpx auto 0;
}

.mall-tabs {
  display: flex;
  align-items: flex-start;
}

.mall-tab {
  margin-right: 36rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
}

.mall-tab:last-child {
  margin-right: 0;
}

.mall-tab--active {
  color: #1e293b;
  font-weight: 700;
}

.mall-tab__dec {
  width: 96rpx;
  height: 8rpx;
  margin-top: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #6ce3a5 0%, #bce774 100%);
}

.mall-banner {
  position: relative;
  margin-top: 14rpx;
  overflow: hidden;
  padding-bottom: 0;
}

.mall-banner-swiper {
  height: 240rpx;
}

.mall-banner-slide {
  width: 100%;
  height: 100%;
}

.mall-banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

.mall-banner-dots {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 10rpx;
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
}

.mall-banner-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.45);
}

.mall-banner-dot + .mall-banner-dot {
  margin-left: 8rpx;
}

.mall-banner-dot--active {
  width: 20rpx;
  background: #ffffff;
}

.mall-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 16rpx;
  margin-bottom: 8rpx;
}

.mall-product {
  width: 342rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.mall-product__thumb-wrap {
  width: 100%;
  height: 296rpx;
  border-radius: 16rpx;
  background: #edf2ef;
  overflow: hidden;
}

.mall-product__thumb {
  width: 100%;
  height: 100%;
  display: block;
}

.mall-product__name {
  margin-top: 12rpx;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.mall-product__meta {
  margin-top: 6rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 32rpx;
}

.mall-product__score {
  display: inline-flex;
  align-items: center;
}

.mall-product__star {
  color: #ffb020;
  font-size: 20rpx;
  margin-right: 6rpx;
}

.mall-product__stock {
  color: #94a3b8;
}

.mall-product__foot {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mall-product__price {
  display: inline-flex;
  align-items: baseline;
}

.mall-product__price-symbol {
  color: #fb2c36;
  opacity: 0.56;
  font-size: 24rpx;
  line-height: 1;
}

.mall-product__price-main {
  margin-left: 4rpx;
  color: #fb2c36;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 700;
}

.mall-product__price-unit {
  margin-left: 6rpx;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1;
}

.mall-product__add {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #33d96f 0%, #22c75d 100%);
  color: #ffffff;
  font-size: 34rpx;
  line-height: 40rpx;
  text-align: center;
}
