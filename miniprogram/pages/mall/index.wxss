.design-page {
  background: #f4f6f8;
}

.mall-header {
  width: 718rpx;
  margin: 6rpx auto 0;
  display: flex;
  align-items: center;
}

.mall-search {
  flex: 1;
  height: 74rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 24rpx rgba(38, 68, 52, 0.08);
  padding: 0 26rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.mall-search__input {
  width: 100%;
  font-size: 24rpx;
  color: #33465a;
}

.mall-city {
  margin-left: 16rpx;
  color: #29614a;
  font-size: 24rpx;
  font-weight: 600;
}

.mall-content {
  width: 718rpx;
  margin: 18rpx auto 0;
}

.mall-notice {
  padding: 22rpx;
  color: #2d4c3d;
  font-size: 24rpx;
  line-height: 1.5;
}

.mall-tabs {
  display: flex;
  margin-top: 18rpx;
}

.mall-tab {
  flex: 1;
  height: 62rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #8090a3;
  font-size: 23rpx;
  font-weight: 500;
  text-align: center;
  line-height: 62rpx;
}

.mall-tab + .mall-tab {
  margin-left: 12rpx;
}

.mall-tab--active {
  background: linear-gradient(135deg, #59ebaf 0%, #bde66b 100%);
  color: #1a4e36;
  font-weight: 700;
}

.mall-banner {
  margin-top: 18rpx;
  padding: 26rpx 24rpx;
  background: linear-gradient(140deg, #173926 0%, #295537 55%, #1f4931 100%);
}

.mall-banner__mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #c5f76d;
  color: #132618;
  font-size: 20rpx;
  font-weight: 700;
}

.mall-banner__title {
  margin-top: 16rpx;
  color: #f2fff2;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 700;
}

.mall-banner__subtitle {
  margin-top: 10rpx;
  color: rgba(228, 246, 234, 0.92);
  font-size: 23rpx;
}

.mall-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 18rpx;
  margin-bottom: 8rpx;
}

.mall-product {
  width: 352rpx;
  margin-bottom: 14rpx;
  padding: 18rpx;
  box-sizing: border-box;
}

.mall-product__thumb {
  width: 100%;
  height: 154rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #d8f4dd 0%, #f2f7e1 100%);
  color: #4e7f63;
  font-size: 50rpx;
  line-height: 154rpx;
  text-align: center;
  font-weight: 700;
}

.mall-product__name {
  margin-top: 12rpx;
  color: #24384a;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
}

.mall-product__meta {
  margin-top: 6rpx;
  color: #8492a2;
  font-size: 21rpx;
}

.mall-product__foot {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mall-product__price-main {
  color: #13a95b;
  font-size: 30rpx;
  font-weight: 700;
}

.mall-product__price-unit {
  margin-left: 4rpx;
  color: #8a95a4;
  font-size: 21rpx;
}

.mall-product__add {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #20d965 0%, #16c958 100%);
  color: #ffffff;
  font-size: 38rpx;
  line-height: 46rpx;
  text-align: center;
}
