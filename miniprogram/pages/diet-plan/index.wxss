.plan-screen {
  background: #f3f4f8;
}

.plan-screen__bg {
  position: absolute;
  left: 50%;
  top: 0;
  width: 750rpx;
  transform: translateX(-50%);
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.plan-scroll {
  position: relative;
  z-index: 1;
}

.plan-nav__title {
  margin-left: 8rpx;
  color: #1e293b;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
}

.plan-wrap {
  width: 702rpx;
  margin: 0 auto;
  padding-bottom: 32rpx;
}

.plan-hero {
  position: relative;
  padding: 22rpx 24rpx 0;
}

.plan-hero__title {
  display: block;
  color: #1e293b;
  font-size: 52rpx;
  line-height: 1.25;
  font-weight: 700;
}

.plan-hero__sub {
  display: block;
  margin-top: 10rpx;
  color: #334155;
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 500;
}

.plan-hero__tag {
  position: absolute;
  right: 24rpx;
  top: 90rpx;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 12rpx;
  background: #cdff71;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.step-panel {
  position: relative;
  margin-top: 18rpx;
  height: 142rpx;
}

.step-panel__bg {
  width: 100%;
  height: 142rpx;
  border-radius: 24rpx;
}

.step-panel__head {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 18rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
}

.step-panel__head-content {
  display: inline-flex;
  align-items: center;
}

.step-panel__left {
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
}

.step-panel__right {
  display: flex;
  align-items: baseline;
  color: #1e293b;
}

.step-panel__right-wrap {
  display: flex;
  align-items: center;
}

.step-panel__divider {
  width: 4rpx;
  height: 20rpx;
  background: #e2e8f0;
  border-radius: 2rpx;
  flex-shrink: 0;
  margin-left: 32rpx;
  margin-right: 32rpx;
}

.step-panel__num {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
  color: #1e293b;
}

.step-panel__slash {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
  color: #1e293b;
}

.step-panel__unit {
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
  color: #1e293b;
}

.step-panel__progress {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 26rpx;
}


.plan-card,
.summary-card {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.plan-card {
  margin-top: 16rpx;
  min-height: 980rpx;
  padding: 28rpx 24rpx;
}

.plan-card--step4 {
  min-height: auto;
}

.plan-step-body {
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

.plan-step-body--step1,
.plan-step-body--step2,
.plan-step-body--step3 {
  min-height: 924rpx;
}

.plan-step-body--step2 .plan-actions {
  margin-top: 130rpx;
}

.plan-step-body--step3 .plan-actions {
  margin-top: 90rpx;}


.plan-card__title-wrap {
  display: block;
  width: 100%;
}

.cycle-item {
  margin-top: 20rpx;
  height: 146rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  background: rgba(244, 247, 250, 0.7);
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cycle-item--active {
  border-color: #00c950;
  background: rgba(255, 255, 255, 0.7);
}

.cycle-item__left {
  display: flex;
  align-items: center;
}

.cycle-item__icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
}

.cycle-item__name {
  display: block;
  color: #1e293b;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 700;
}

.cycle-item--active .cycle-item__name {
  color: #008435;
}

.cycle-item__desc {
  display: block;
  margin-top: 10rpx;
  color: #475569;
  font-size: 28rpx;
  line-height: 1;
}

.cycle-item__right {
  display: flex;
  align-items: center;
}

.cycle-item__price {
  color: #1e293b;
  line-height: 1;
}

.cycle-item--active .cycle-item__price {
  color: #008435;
}

.cycle-item__currency {
  font-size: 24rpx;
  opacity: 0.55;
  margin-right: 4rpx;
}

.cycle-item__num {
  font-size: 48rpx;
  font-weight: 700;
}

.cycle-item__check {
  margin-left: 14rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #b8c5d4;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
  box-sizing: border-box;
}

.cycle-item__check--active {
  border-color: #16c95b;
  background: #16c95b;
}

.constitution-grid {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.constitution-item {
  width: 318rpx;
  height: 120rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  background: rgba(255, 255, 255, 0.78);
  box-sizing: border-box;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.constitution-item--active {
  border-color: #00c950;
  background: rgba(255, 255, 255, 0.9);
}

.constitution-item__name {
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 700;
}

.constitution-item__dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #cbd5e1;
  box-sizing: border-box;
  color: #fff;
  font-size: 24rpx;
  line-height: 42rpx;
  text-align: center;
  flex-shrink: 0;
}

.constitution-item__dot--active {
  border-color: #00c950;
  background: #00c950;
}

.constitution-item__check-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.meal-row {
  margin-top: 16rpx;
  height: 112rpx;
  border-radius: 24rpx;
  background: #f4f7fa;
  border: none;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meal-row__left {
  display: flex;
  align-items: center;
  flex: 1;
}

.meal-row__icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 24rpx;
  background: linear-gradient(133deg, #7cee89 0%, #2bc383 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.meal-row__icon {
  width: 32rpx;
  height: 32rpx;
}

.meal-row__name {
  margin-left: 20rpx;
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 700;
}

.meal-row__right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.meal-row__time {
  color: #cbd5e1;
  font-size: 28rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
}

.meal-row__time--active {
  color: #1e293b;
  font-weight: 700;
}

.meal-row__plus {
  margin-left: 20rpx;
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.pref-grid {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
}

.pref-title-wrap {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
}

.pref-title-sub {
  color: #475569;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 32rpx;
  margin-bottom: 2rpx;
}

.pref-chip {
  height: 72rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  background: #ffffff;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 68rpx;
  text-align: center;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.pref-chip:active {
  opacity: 0.7;
}

.pref-chip--hover {
  opacity: 0.7;
}

.pref-chip--active {
  border-color: transparent;
  background: #00c950;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 201, 80, 0.3);
}

.pref-subtitle-wrap {
  margin-top: 8rpx;
}

.pref-textarea {
  margin-top: 12rpx;
  width: 100%;
  height: 240rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e2e8f0;
  background: #f3f4f6;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.5;
}

.pref-textarea__placeholder {
  color: #cbd5e1;
}

.plan-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.plan-actions--single {
  margin-top: 24rpx;
}

.plan-actions--step4 {
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  height: 80rpx;
  border-radius: 24rpx;
  text-align: center;
  line-height: 80rpx;
  font-size: 32rpx;
}

.action-btn--ghost {
  width: 314rpx;
  border: 2rpx solid #dbe3ec;
  background: rgba(226, 245, 239, 0.76);
  color: #1e293b;
  font-weight: 600;
}

.action-btn--primary {
  width: 314rpx;
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
  font-weight: 700;
}

.action-btn--full {
  width: 100%;
}

.step-link {
  display: block;
  margin-top: 20rpx;
  text-align: center;
  color: #16a34a;
  font-size: 24rpx;
  line-height: 1.5;
  text-decoration: underline;
}

.meal-divider {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  border-top: 2rpx solid #e2e8f0;
}

.meal-tip {
  display: block;
  margin-top: 16rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.6;
}

.summary-card {
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
}

.summary-card__tag {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 22rpx 0 24rpx 0;
  background: linear-gradient(127deg, #fffad6 0%, #ffd46f 100%);
  color: #634703;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
}

.summary-row {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.45;
}

.summary-row text:last-child {
  max-width: 420rpx;
  text-align: right;
}

.summary-divider {
  margin-top: 18rpx;
  border-top: 2rpx dashed #d9e0ea;
}

.summary-row--price {
  color: #008435;
  font-weight: 700;
}
