.page-with-nav {
  position: relative;
  min-height: 100vh;
  background: transparent;
}

.page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.page-wrap {
  position: relative;
  z-index: 1;
}

.page-wrap {
  width: 702rpx;
  margin: 0 auto;
  padding-bottom: 32rpx;
}

.page-wrap--no-title {
  padding-top: 8rpx;
}

.page-title-block {
  margin-top: 8rpx;
}

.page-title {
  color: #1e293b;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
}

.page-subtitle {
  margin-top: 6rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.5;
}

.mini-nav__title {
  margin-left: 10rpx;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
}

.glass-card {
  margin-top: 14rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
  box-shadow: none;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.card-head {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
}

.card-title {
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
}

.card-dec {
  width: 90rpx;
  margin-top: 4rpx;
}

.tag-chip {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  border-radius: 16rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.btn-primary {
  height: 84rpx;
  border-radius: 20rpx;
  text-align: center;
  line-height: 84rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
}

.btn-secondary {
  height: 84rpx;
  border-radius: 20rpx;
  text-align: center;
  line-height: 84rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: 2rpx solid #cdd5df;
  color: #475569;
  background: rgba(255, 255, 255, 0.78);
}

.muted-text {
  color: #64748b;
}

.list-arrow {
  color: #94a3b8;
  font-size: 26rpx;
}
