.diet-page {
  background: transparent;
}

.diet-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.diet-wrap {
  position: relative;
  z-index: 1;
}

.diet-page .card-panel {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
  box-shadow: none;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.diet-wrap {
  width: 702rpx;
  margin: 6rpx auto 0;
}

.diet-search-row {
  display: flex;
  align-items: center;
}

.diet-search {
  flex: 1;
  height: 64rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.diet-search__icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.7;
}

.diet-search__placeholder {
  margin-left: 10rpx;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.3;
}

.diet-cart {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  margin-left: 14rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.diet-cart__icon {
  width: 32rpx;
  height: 32rpx;
}

.diet-cart__badge {
  position: absolute;
  right: -4rpx;
  top: -6rpx;
  min-width: 32rpx;
  height: 28rpx;
  border-radius: 14rpx;
  padding: 0 8rpx;
  background: #ffb900;
  color: #1e293b;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
  font-weight: 700;
  box-sizing: border-box;
}

.diet-custom-card,
.diet-week-card {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  background: rgba(255, 255, 255, 0.7);
}

.diet-custom-card {
  position: relative;
  overflow: hidden;
  min-height: 196rpx;
}

.diet-custom__title-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
}

.diet-custom__title {
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.diet-custom__desc {
  margin-left: 8rpx;
  color: #008435;
  font-size: 24rpx;
  line-height: 1.35;
}

.diet-custom__note {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  min-height: 50rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: rgba(0, 201, 80, 0.16);
  color: #16653e;
  font-size: 22rpx;
}

.diet-custom__cta {
  margin-top: 18rpx;
  width: 178rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
  font-size: 24rpx;
  line-height: 58rpx;
  text-align: center;
  font-weight: 700;
}

.diet-custom__illus {
  position: absolute;
  right: -8rpx;
  bottom: -10rpx;
  width: 228rpx;
  height: 154rpx;
  opacity: 0.78;
  pointer-events: none;
}

.diet-week__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.diet-week__title {
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.diet-week__status {
  height: 42rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  background: rgba(0, 201, 80, 0.16);
  color: #008435;
  font-size: 20rpx;
  line-height: 42rpx;
}

.diet-week__meta {
  margin-top: 8rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.4;
}

.diet-week__meta-num {
  font-size: 30rpx;
  font-weight: 700;
}

.diet-week__progress-track {
  position: relative;
  margin-top: 12rpx;
  height: 12rpx;
  border-radius: 10rpx;
  background: rgba(0, 201, 80, 0.14);
}

.diet-week__progress-fill {
  height: 12rpx;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #00c950 0%, #77e258 100%);
}

.diet-week__progress-dot {
  position: absolute;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #f8ffef;
  border: 2rpx solid #6fe066;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}

.diet-week__list {
  margin-top: 14rpx;
}

.diet-week__item {
  height: 64rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.82);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.diet-week__item + .diet-week__item {
  margin-top: 10rpx;
}

.diet-week__item-left {
  display: flex;
  align-items: center;
  color: #1e293b;
  font-size: 24rpx;
}

.diet-week__item-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #00c950;
  margin-right: 10rpx;
}

.diet-week__item-time {
  color: #64748b;
  font-size: 22rpx;
}

.diet-week__retune {
  margin-top: 14rpx;
  width: 152rpx;
  height: 52rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  color: #334155;
  font-size: 22rpx;
  line-height: 52rpx;
  text-align: center;
}

.diet-tabs {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-start;
}

.diet-tab {
  margin-right: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 400;
}

.diet-tab--active {
  font-weight: 700;
}

.diet-tab__dec {
  width: 96rpx;
  margin-top: 2rpx;
}

.diet-recipes {
  margin-top: 14rpx;
  padding-bottom: 24rpx;
}

.diet-recipe {
  padding: 16rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.72);
}

.diet-recipe + .diet-recipe {
  margin-top: 12rpx;
}

.diet-recipe__cover {
  width: 114rpx;
  height: 114rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(110, 221, 145, 0.18);
}

.diet-recipe__body {
  margin-left: 14rpx;
  flex: 1;
  min-width: 0;
}

.diet-recipe__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.diet-recipe__name {
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  max-width: 320rpx;
}

.diet-recipe__price {
  margin-left: 12rpx;
  white-space: nowrap;
}

.diet-recipe__price-currency {
  color: #00a340;
  font-size: 22rpx;
  font-weight: 700;
}

.diet-recipe__price-main {
  color: #00a340;
  font-size: 32rpx;
  font-weight: 700;
}

.diet-recipe__price-unit {
  margin-left: 4rpx;
  color: #94a3b8;
  font-size: 20rpx;
}

.diet-recipe__tags {
  display: flex;
  margin-top: 8rpx;
}

.diet-recipe__tag {
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(0, 201, 80, 0.14);
  color: #008435;
  font-size: 20rpx;
  line-height: 38rpx;
}

.diet-recipe__tag + .diet-recipe__tag {
  margin-left: 8rpx;
}

.diet-recipe__type {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
}
