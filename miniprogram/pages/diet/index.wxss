.diet-page {
  background: #f4f6f8;
}

.diet-head {
  width: 718rpx;
  margin: 8rpx auto 0;
  display: flex;
  align-items: center;
}

.diet-search {
  flex: 1;
  height: 74rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #9ba7b5;
  font-size: 24rpx;
  line-height: 74rpx;
  padding-left: 26rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 24rpx rgba(38, 68, 52, 0.08);
}

.diet-mode {
  margin-left: 12rpx;
  height: 60rpx;
  border-radius: 999rpx;
  padding: 0 20rpx;
  background: linear-gradient(135deg, #1cd565 0%, #82e85a 100%);
  color: #163922;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 60rpx;
}

.diet-content {
  width: 718rpx;
  margin: 18rpx auto 0;
}

.diet-tabs {
  display: flex;
}

.diet-tab {
  flex: 1;
  height: 62rpx;
  border-radius: 18rpx;
  text-align: center;
  line-height: 62rpx;
  font-size: 23rpx;
  color: #8392a0;
  background: rgba(255, 255, 255, 0.78);
}

.diet-tab + .diet-tab {
  margin-left: 12rpx;
}

.diet-tab--active {
  color: #1c4c37;
  background: linear-gradient(135deg, #58ecae 0%, #c9e768 100%);
  font-weight: 700;
}

.diet-plan {
  margin-top: 18rpx;
  padding: 24rpx;
}

.diet-plan__note {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  color: #355546;
  font-size: 22rpx;
  background: rgba(70, 204, 126, 0.12);
}

.diet-plan__action {
  margin-top: 18rpx;
  width: 180rpx;
  height: 58rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 58rpx;
  color: #133322;
  font-size: 23rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #1ed968 0%, #7ee95d 100%);
}

.diet-week {
  margin-top: 18rpx;
  border-radius: 18rpx;
  background: #f0f7f2;
  padding: 16rpx 18rpx;
}

.diet-week__head {
  display: flex;
  justify-content: space-between;
}

.diet-week__title {
  color: #294133;
  font-size: 24rpx;
  font-weight: 700;
}

.diet-week__status {
  height: 40rpx;
  border-radius: 999rpx;
  padding: 0 14rpx;
  background: rgba(56, 196, 105, 0.18);
  color: #1d804f;
  font-size: 20rpx;
  line-height: 40rpx;
}

.diet-week__meta {
  margin-top: 8rpx;
  color: #728295;
  font-size: 22rpx;
}

.diet-week__list {
  margin-top: 10rpx;
}

.diet-week__item {
  height: 52rpx;
  border-radius: 12rpx;
  padding: 0 12rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #3d4f61;
  font-size: 22rpx;
}

.diet-week__item + .diet-week__item {
  margin-top: 8rpx;
}

.diet-recipes {
  margin-top: 18rpx;
  margin-bottom: 8rpx;
}

.diet-recipe {
  padding: 20rpx;
}

.diet-recipe + .diet-recipe {
  margin-top: 12rpx;
}

.diet-recipe__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.diet-recipe__name {
  color: #24384b;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.diet-recipe__price-main {
  color: #17ad60;
  font-size: 30rpx;
  font-weight: 700;
}

.diet-recipe__price-unit {
  margin-left: 4rpx;
  color: #8391a0;
  font-size: 22rpx;
}

.diet-recipe__tags {
  display: flex;
  margin-top: 10rpx;
}

.diet-recipe__tag {
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(95, 208, 139, 0.15);
  color: #238752;
  font-size: 21rpx;
  line-height: 40rpx;
}

.diet-recipe__tag + .diet-recipe__tag {
  margin-left: 8rpx;
}

.diet-recipe__type {
  display: block;
  margin-top: 10rpx;
  color: #7f8f9f;
  font-size: 22rpx;
}
