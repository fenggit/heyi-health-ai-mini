.constitution-page {
  background: transparent;
}

.constitution-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.constitution-wrap {
  position: relative;
  z-index: 1;
}

.constitution-page .mini-nav__title {
  margin-left: 0;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.constitution-wrap {
  width: 702rpx;
  margin: 0 auto;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.constitution-page .card-panel {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
  box-shadow: none;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.constitution-main-card {
  position: relative;
  margin-top: 18rpx;
  padding: 14rpx 0 20rpx;
  background: rgba(255, 255, 255, 0.38);
}

.constitution-head {
  position: relative;
  padding: 4rpx 24rpx 0;
}

.constitution-title {
  color: #1e293b;
  font-size: 48rpx;
  line-height: 60rpx;
  font-weight: 700;
}

.constitution-subtitle {
  margin-top: 10rpx;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 500;
}

.constitution-tag {
  position: absolute;
  right: 24rpx;
  top: 58rpx;
  min-width: 128rpx;
  height: 40rpx;
  border-radius: 12rpx;
  padding: 0 16rpx;
  background: #cdff71;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 40rpx;
  text-align: center;
  box-sizing: border-box;
  font-weight: 700;
}

.constitution-metrics {
  padding: 0 24rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.constitution-metric {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.constitution-metric + .constitution-metric {
  margin-left: 12rpx;
}

.constitution-metric__value {
  color: #1e293b;
  font-size: 36rpx;
  line-height: 42rpx;
  font-weight: 700;
}

.constitution-metric__label {
  margin-top: 8rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 400;
}

.constitution-benefits-title {
  position: relative;
  display: inline-block;
  margin-top: 28rpx;
  margin-left: 32rpx;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.constitution-benefits-title::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -2rpx;
  width: 90rpx;
  height: 10rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #7cee89 0%, #2bc383 100%);
}

.constitution-benefit-item {
  margin-top: 18rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
}

.constitution-benefit-item__icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.constitution-benefit-item__text {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 30rpx;
  font-weight: 400;
}

.constitution-scan-card {
  margin: 24rpx 16rpx 0;
  border-radius: 24rpx;
  background: rgba(231, 247, 239, 0.5);
  padding: 16rpx 0 22rpx;
}

.constitution-scan-head {
  display: flex;
  align-items: center;
  justify-content: center;
}

.constitution-scan-head__line {
  width: 200rpx;
  height: 2rpx;
  background: #ffffff;
}

.constitution-scan-head__title {
  margin: 0 16rpx;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 30rpx;
  font-weight: 500;
}

.constitution-qr-frame {
  width: 400rpx;
  height: 400rpx;
  margin: 24rpx auto 0;
  padding: 24rpx;
  border-radius: 32rpx;
  border: 4rpx solid #00c950;
  box-sizing: border-box;
  background: #ffffff;
}

.constitution-qr {
  display: block;
  width: 100%;
  height: 100%;
}

.constitution-scan-hint {
  margin-top: 24rpx;
  color: #00674a;
  font-size: 28rpx;
  line-height: 30rpx;
  text-align: center;
  font-weight: 700;
}
