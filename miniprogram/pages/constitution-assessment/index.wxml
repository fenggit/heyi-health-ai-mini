<view class="constitution-page design-page">
  <image class="constitution-page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <view class="mini-nav__title">{{navTitle}}</view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="constitution-wrap">
    <view class="constitution-head">
      <view class="constitution-title">{{welcomeTitle}}</view>
      <view class="constitution-subtitle">{{welcomeSubtitle}}</view>
      <view class="constitution-tag">{{tag}}</view>
    </view>

    <view class="card-panel constitution-main-card">
      <view class="constitution-metrics">
        <block wx:for="{{metrics}}" wx:key="id">
          <view class="constitution-metric constitution-metric--{{index}}">
            <text class="constitution-metric__value">{{item.value}}</text>
            <text class="constitution-metric__label">{{item.label}}</text>
          </view>
        </block>
      </view>

      <view class="constitution-benefits-title">{{benefitsTitle}}</view>

      <block wx:for="{{benefits}}" wx:key="*this">
        <view class="constitution-benefit-item">
          <image class="constitution-benefit-item__icon" src="/assets/analysis/check_green.png" mode="aspectFit" />
          <text class="constitution-benefit-item__text">{{item}}</text>
        </view>
      </block>

      <view class="constitution-scan-card">
        <view class="constitution-scan-head">
          <view class="constitution-scan-head__line"></view>
          <text class="constitution-scan-head__title">{{scanTitle}}</text>
          <view class="constitution-scan-head__line"></view>
        </view>

        <view class="constitution-qr-frame" bindtap="previewQr">
          <image class="constitution-qr" src="{{qrImage}}" mode="aspectFill" />
        </view>

        <view class="constitution-scan-hint">{{scanHint}}</view>
      </view>
    </view>
  </view>
</view>
