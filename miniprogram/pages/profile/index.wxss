.profile-page {
  background: transparent;
}

.profile-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.profile-title,
.profile-content {
  position: relative;
  z-index: 1;
}

.profile-page .card-panel {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: none;
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.profile-title {
  width: 702rpx;
  margin: 0 auto;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.profile-content {
  width: 702rpx;
  margin: 8rpx auto 0;
}

.profile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profile-user {
  display: flex;
  align-items: center;
  min-width: 0;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(140deg, #6ce3a5 0%, #bce774 100%);
  color: #0f5132;
  font-size: 48rpx;
  line-height: 120rpx;
  text-align: center;
  font-weight: 700;
}

.profile-user__meta {
  margin-left: 16rpx;
  min-width: 0;
}

.profile-name {
  color: #1e293b;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  max-width: 320rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-id {
  margin-top: 10rpx;
  color: #475569;
  font-size: 30rpx;
  line-height: 1.2;
}

.profile-quick-entry {
  width: 188rpx;
  height: 64rpx;
  border-radius: 20rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.profile-quick-entry__icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.profile-member {
  margin-top: 12rpx;
  padding: 16rpx 20rpx 18rpx;
  border: none;
  background: linear-gradient(120deg, rgba(119, 237, 207, 0.88) 0%, rgba(179, 235, 145, 0.86) 100%);
}

.profile-member__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.profile-member__info {
  display: inline-flex;
  align-items: center;
  color: #131313;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.profile-member__icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.profile-member__action {
  height: 56rpx;
  border-radius: 18rpx;
  padding: 0 20rpx;
  background: #131313;
  color: #cdff71;
  font-size: 24rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.profile-member__divider {
  height: 2rpx;
  margin: 14rpx -20rpx 0;
  background: rgba(255, 255, 255, 0.62);
}

.profile-stats-head {
  margin-top: 14rpx;
}

.section-title {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.profile-stats {
  margin-top: 8rpx;
  display: flex;
}

.profile-stat {
  flex: 1;
  text-align: center;
}

.profile-stat__value {
  color: #1e293b;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
}

.profile-stat__label {
  display: block;
  margin-top: 6rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.4;
}

.profile-section {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  padding: 0 24rpx;
  overflow: hidden;
}

.profile-section__head {
  padding: 18rpx 0 10rpx;
}

.profile-item {
  min-height: 88rpx;
  border-bottom: 2rpx solid #e6edf3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.3;
}

.profile-item:last-child {
  border-bottom: 0;
}

.profile-item__main {
  display: inline-flex;
  align-items: center;
}

.profile-item__icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 14rpx;
}

.profile-item__arrow {
  color: #a3b0bf;
  font-size: 24rpx;
}

.member-layer {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20000;
  pointer-events: none;
}

.member-layer--show {
  pointer-events: auto;
}

.member-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(30, 41, 59, 0.5);
  z-index: 1;
}

.member-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(100vh - 178rpx);
  border-radius: 24rpx 24rpx 0 0;
  background: #f3f4f8;
  z-index: 2;
  transform: translate3d(0, 110%, 0);
  transition: transform 0.24s ease-out;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  pointer-events: none;
}

.member-sheet--show {
  transform: translate3d(0, 0, 0);
  pointer-events: auto;
}

.member-sheet__top {
  padding: 24rpx 0 24rpx;
  background: linear-gradient(116deg, #4ae8cf 0%, #cdec4a 100%);
  flex-shrink: 0;
}

.member-sheet__title {
  text-align: center;
  color: #1e293b;
  font-size: 32rpx;
  line-height: 36rpx;
  font-weight: 700;
}

.member-sheet__plan-scroll {
  margin-top: 12rpx;
  white-space: nowrap;
}

.member-sheet__plan-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 48rpx 24rpx 4rpx;
}

.member-sheet__plan-item {
  width: 310rpx;
  height: 144rpx;
  border-radius: 24rpx;
  padding-top: 0;
  box-sizing: border-box;
  border: 2rpx solid rgba(255, 255, 255, 1);
  background: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
  position: relative;
}

.member-sheet__plan-item--active {
  border-color: #00c950;
  background: #ffffff;
}

.member-sheet__plan-chip {
  position: absolute;
  top: -48rpx;
  left: 0;
  width: 244rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 24rpx;
  background: #f6d800;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
}

.member-sheet__plan-chip--dark {
  background: #111827;
  color: #cdff71;
}

.member-sheet__plan-chip--compact {
  width: 160rpx;
}

.member-sheet__plan-price-wrap {
  margin-top: 42rpx;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  color: #1e293b;
  text-align: center;
}

.member-sheet__plan-currency {
  font-size: 40rpx;
  line-height: 56rpx;
  color: rgba(30, 41, 59, 0.55);
}

.member-sheet__plan-price {
  font-size: 64rpx;
  line-height: 64rpx;
  font-weight: 700;
}

.member-sheet__plan-unit {
  margin-left: 6rpx;
  font-size: 28rpx;
  line-height: 44rpx;
  color: rgba(30, 41, 59, 0.55);
}

.member-sheet__body {
  margin: 8rpx 24rpx 0;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  padding: 20rpx 24rpx 24rpx;
  box-sizing: border-box;
  flex: 1;
  overflow-y: auto;
}

.member-sheet__section-title {
  margin-top: 4rpx;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.member-sheet__section-title--gap {
  margin-top: 24rpx;
}

.member-sheet__benefit-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 30rpx;
}

.member-sheet__benefit-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.member-sheet__welfare-grid {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  row-gap: 16rpx;
  column-gap: 18rpx;
}

.member-sheet__welfare-item {
  width: 318rpx;
  height: 168rpx;
  border-radius: 24rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 30rpx;
  font-weight: 500;
  text-align: center;
}

.member-sheet__welfare-icon {
  width: 48rpx;
  height: 48rpx;
}

.member-sheet__welfare-text {
  width: 100%;
  text-align: center;
}

.member-sheet__faq-item {
  margin-top: 12rpx;
}

.member-sheet__faq-q,
.member-sheet__faq-a {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 42rpx;
}

.member-sheet__faq-a {
  margin-top: 2rpx;
}

.member-sheet__action-bar {
  margin-top: 12rpx;
  padding: 10rpx 0 calc(10rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  flex-shrink: 0;
}

.member-sheet__action-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 0 56rpx;
}

.member-sheet__action {
  width: 310rpx;
  height: 80rpx;
  border-radius: 24rpx;
  text-align: center;
  line-height: 80rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.member-sheet__action--cancel {
  color: #1e293b;
  background: linear-gradient(90deg, #e2efec 0%, #dbeee8 100%);
}

.member-sheet__action--open {
  color: #1e293b;
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
}
