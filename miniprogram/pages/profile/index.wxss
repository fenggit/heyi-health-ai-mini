.profile-content {
  width: 718rpx;
  margin: 8rpx auto 0;
}

.profile-user {
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #57e7ab 0%, #b9e86c 100%);
  color: #1d4e35;
  font-size: 44rpx;
  line-height: 108rpx;
  text-align: center;
  font-weight: 700;
}

.profile-user__meta {
  margin-left: 18rpx;
}

.profile-name {
  color: #21384b;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
}

.profile-id {
  margin-top: 8rpx;
  color: #7b8a99;
  font-size: 22rpx;
}

.profile-member {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  background: linear-gradient(140deg, #202f45 0%, #2f4a5d 100%);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.profile-member__info {
  color: #e7f7ee;
  font-size: 24rpx;
}

.profile-member__action {
  height: 50rpx;
  border-radius: 999rpx;
  padding: 0 18rpx;
  background: linear-gradient(135deg, #59ecae 0%, #cbe86a 100%);
  color: #1d4d34;
  font-size: 22rpx;
  line-height: 50rpx;
  font-weight: 700;
}

.profile-stats {
  margin-top: 16rpx;
  padding: 18rpx;
  display: flex;
}

.profile-stat {
  flex: 1;
  text-align: center;
}

.profile-stat__value {
  color: #253a4d;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
}

.profile-stat__label {
  display: block;
  margin-top: 8rpx;
  color: #7f8d9c;
  font-size: 22rpx;
}

.profile-section {
  margin-top: 16rpx;
  padding: 20rpx;
}

.profile-section--last {
  margin-bottom: 8rpx;
}

.profile-item {
  min-height: 72rpx;
  border-bottom: 1rpx solid #eef2f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #34475a;
  font-size: 25rpx;
}

.profile-item:last-child {
  border-bottom: 0;
}

.profile-item__arrow {
  color: #b2bcc8;
  font-size: 24rpx;
}
