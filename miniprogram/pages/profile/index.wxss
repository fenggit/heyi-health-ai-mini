.profile-page {
  background: transparent;
}

.profile-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.profile-title,
.profile-content {
  position: relative;
  z-index: 1;
}

.profile-page .card-panel {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: none;
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.profile-title {
  width: 702rpx;
  margin: 0 auto;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.profile-content {
  width: 702rpx;
  margin: 8rpx auto 0;
}

.profile-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profile-user {
  display: flex;
  align-items: center;
  min-width: 0;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(140deg, #6ce3a5 0%, #bce774 100%);
  color: #0f5132;
  font-size: 48rpx;
  line-height: 120rpx;
  text-align: center;
  font-weight: 700;
}

.profile-user__meta {
  margin-left: 16rpx;
  min-width: 0;
}

.profile-name {
  color: #1e293b;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  max-width: 320rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-id {
  margin-top: 10rpx;
  color: #475569;
  font-size: 30rpx;
  line-height: 1.2;
}

.profile-quick-entry {
  width: 188rpx;
  height: 64rpx;
  border-radius: 20rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
}

.profile-quick-entry__icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.profile-member {
  margin-top: 12rpx;
  padding: 16rpx 20rpx 18rpx;
  border: none;
  background: linear-gradient(120deg, rgba(119, 237, 207, 0.88) 0%, rgba(179, 235, 145, 0.86) 100%);
}

.profile-member__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.profile-member__info {
  display: inline-flex;
  align-items: center;
  color: #131313;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.profile-member__icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.profile-member__action {
  height: 56rpx;
  border-radius: 18rpx;
  padding: 0 20rpx;
  background: #131313;
  color: #cdff71;
  font-size: 24rpx;
  line-height: 56rpx;
  font-weight: 500;
}

.profile-member__divider {
  height: 2rpx;
  margin: 14rpx -20rpx 0;
  background: rgba(255, 255, 255, 0.62);
}

.profile-stats-head {
  margin-top: 14rpx;
}

.section-title {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 700;
}

.profile-stats {
  margin-top: 8rpx;
  display: flex;
}

.profile-stat {
  flex: 1;
  text-align: center;
}

.profile-stat__value {
  color: #1e293b;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
}

.profile-stat__label {
  display: block;
  margin-top: 6rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.4;
}

.profile-section {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  padding: 0 24rpx;
  overflow: hidden;
}

.profile-section__head {
  padding: 18rpx 0 10rpx;
}

.profile-item {
  min-height: 88rpx;
  border-bottom: 2rpx solid #e6edf3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.3;
}

.profile-item:last-child {
  border-bottom: 0;
}

.profile-item__main {
  display: inline-flex;
  align-items: center;
}

.profile-item__icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 14rpx;
}

.profile-item__arrow {
  color: #a3b0bf;
  font-size: 24rpx;
}
