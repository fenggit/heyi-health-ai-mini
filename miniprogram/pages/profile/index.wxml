<view class="profile-page design-page design-page--with-tab">
  <image class="profile-page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="profile-title">{{pageTitle}}</view>

  <view class="profile-content">
    <view class="profile-header">
      <view class="profile-user">
        <view class="profile-avatar">合</view>
        <view class="profile-user__meta">
          <view class="profile-name">{{user.nickname}}</view>
          <view class="profile-id">ID：{{user.userId}}</view>
        </view>
      </view>
      <view class="card-panel profile-quick-entry" data-name="{{quickEntry.name}}" bindtap="openItem">
        <image class="profile-quick-entry__icon" src="{{quickEntry.icon}}" mode="aspectFit" />
        <text>{{quickEntry.name}}</text>
      </view>
    </view>

    <view class="card-panel profile-member">
      <view class="profile-member__head">
        <view class="profile-member__info">
          <image class="profile-member__icon" src="/assets/profile/vip.png" mode="aspectFit" />
          <text>{{user.memberLevel}}：{{user.points}} 积分</text>
        </view>
        <view class="profile-member__action" data-name="会员升级" bindtap="openItem">会员升级</view>
      </view>
      <view class="profile-member__divider"></view>
      <view class="profile-stats-head">
        <text class="section-title">我的数据</text>
      </view>
      <view class="profile-stats">
        <block wx:for="{{stats}}" wx:key="label">
          <view class="profile-stat">
            <text class="profile-stat__value">{{item.value}}</text>
            <text class="profile-stat__label">{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>

    <view class="card-panel profile-section">
      <view class="profile-section__head">
        <text class="section-title">全部功能</text>
      </view>
      <block wx:for="{{featureMenus}}" wx:key="name">
        <view class="profile-item" data-name="{{item.name}}" bindtap="openItem">
          <view class="profile-item__main">
            <image class="profile-item__icon" src="{{item.icon}}" mode="aspectFit" />
            <text>{{item.name}}</text>
          </view>
          <text class="profile-item__arrow">></text>
        </view>
      </block>
    </view>
  </view>

  <view class="member-layer {{showMemberSheet ? 'member-layer--show' : ''}}">
    <view wx:if="{{showMemberSheet}}" class="member-mask" bindtap="closeMemberSheet"></view>
    <view class="member-sheet {{showMemberSheet ? 'member-sheet--show' : ''}}" catchtap="noop" catchtouchmove="noop">
      <view class="member-sheet__top">
        <view class="member-sheet__title">会员升级</view>
        <scroll-view class="member-sheet__plan-scroll" scroll-x="true" show-scrollbar="false">
          <view class="member-sheet__plan-list">
            <block wx:for="{{memberPlans}}" wx:key="id">
              <view
                class="member-sheet__plan-item {{selectedMemberPlanId === item.id ? 'member-sheet__plan-item--active' : ''}}"
                data-id="{{item.id}}"
                bindtap="selectMemberPlan"
              >
                <view
                  class="member-sheet__plan-chip {{item.dark ? 'member-sheet__plan-chip--dark' : ''}} {{item.compact ? 'member-sheet__plan-chip--compact' : ''}}"
                >
                  {{item.title}}
                </view>
                <view class="member-sheet__plan-price-wrap">
                  <text class="member-sheet__plan-currency">¥</text>
                  <text class="member-sheet__plan-price">{{item.price}}</text>
                  <text wx:if="{{item.unit}}" class="member-sheet__plan-unit">{{item.unit}}</text>
                </view>
              </view>
            </block>
          </view>
        </scroll-view>
      </view>

      <view class="member-sheet__body">
        <view class="member-sheet__section-title">会员权益</view>
        <block wx:for="{{memberBenefits}}" wx:key="*this">
          <view class="member-sheet__benefit-row">
            <image class="member-sheet__benefit-icon" src="/assets/analysis/check_green.png" mode="aspectFit" />
            <text>{{item}}</text>
          </view>
        </block>

        <view class="member-sheet__section-title member-sheet__section-title--gap">会员专属福利</view>
        <view class="member-sheet__welfare-grid">
          <block wx:for="{{memberWelfares}}" wx:key="label">
            <view class="member-sheet__welfare-item">
              <image class="member-sheet__welfare-icon" src="{{item.icon}}" mode="aspectFit" />
              <view class="member-sheet__welfare-text">{{item.label}}</view>
            </view>
          </block>
        </view>

        <view class="member-sheet__section-title member-sheet__section-title--gap">常见问题</view>
        <block wx:for="{{memberFaqs}}" wx:key="id">
          <view class="member-sheet__faq-item">
            <view class="member-sheet__faq-q">{{item.q}}</view>
            <view class="member-sheet__faq-a">{{item.a}}</view>
          </view>
        </block>
      </view>

      <view class="member-sheet__action-bar">
        <view class="member-sheet__action-row">
          <view class="member-sheet__action member-sheet__action--cancel" bindtap="closeMemberSheet">取消</view>
          <view class="member-sheet__action member-sheet__action--open" bindtap="confirmMemberUpgrade">立即开通</view>
        </view>
      </view>
    </view>
  </view>
</view>
