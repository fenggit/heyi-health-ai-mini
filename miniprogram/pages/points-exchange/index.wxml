<view class="points-page design-page page-with-nav">
  <image class="page-bg" src="/assets/bg_img.png" mode="widthFix" />

  <view class="mini-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="mini-nav__inner" style="height: {{navBarHeight}}px;">
      <view class="mini-nav__back" bindtap="handleBack">
        <image class="mini-nav__back-icon" src="/assets/analysis/nav_back.png" mode="aspectFit" />
      </view>
      <view class="mini-nav__title">{{navTitle}}</view>
    </view>
    <view
      class="mini-nav__capsule-space"
      style="width: {{menuWidth}}px; height: {{menuHeight}}px; right: {{menuRight}}px; top: {{menuTop}}px;"
    ></view>
  </view>

  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="page-wrap">
    <view class="points-head">
      <view>
        <view class="page-title">{{pageTitle}}</view>
        <view class="page-subtitle">{{pageSubTitle}}</view>
      </view>
      <view class="points-rule-btn" bindtap="openRules">积分获取规则</view>
    </view>

    <view class="glass-card points-summary">
      <view class="points-summary-top">
        <view class="points-summary-title">我的积分：{{myPoints}}</view>
        <view class="points-summary-member">{{memberLevel}}</view>
      </view>
      <view class="points-summary-bottom">
        <view class="points-summary-label">本月获得</view>
        <view class="points-summary-income">+{{monthlyIncome}}</view>
      </view>
    </view>

    <view class="glass-card points-list">
      <view class="points-list-title">可兑换礼品</view>
      <block wx:for="{{rewardItems}}" wx:key="id" wx:for-item="reward">
        <view class="points-item">
          <view class="points-item-left">
            <view class="points-item-left__title">{{reward.leftTitle}}</view>
            <view class="points-item-left__sub">{{reward.leftSub}}</view>
          </view>
          <view class="points-item-main">
            <view class="points-item-main__name">{{reward.name}}</view>
            <view class="points-item-main__stock">库存 {{reward.stock}}</view>
          </view>
          <view class="points-item-btn" data-id="{{reward.id}}" bindtap="redeem">立即兑换</view>
        </view>
      </block>
    </view>
  </view>
</view>
