<view class="design-page">
  <view class="page-top-gap" style="height: {{topInset}}px;"></view>

  <view class="quiz-wrap">
    <view class="quiz-head card-panel">
      <view class="quiz-head__title">{{title}}</view>
      <view class="quiz-head__subtitle">{{subTitle}}</view>
      <view class="quiz-progress">步骤一：问卷分析</view>
      <view class="quiz-progress__count">{{currentIndex + 1}} / {{questions.length}} 题</view>
    </view>

    <view class="quiz-card card-panel" wx:if="{{questions.length}}">
      <view class="quiz-question">{{questions[currentIndex].title}}</view>
      <view class="quiz-tip">小提示：{{tips}}</view>

      <view class="quiz-options">
        <block wx:for="{{questions[currentIndex].options}}" wx:key="*this">
          <view
            class="quiz-option {{answers[currentIndex] === index ? 'quiz-option--active' : ''}}"
            data-index="{{index}}"
            bindtap="chooseOption"
          >
            {{item}}
          </view>
        </block>
      </view>
    </view>

    <view class="quiz-footer card-panel">
      <view class="quiz-disclaimer">本结果由AI生成，仅供娱乐与生活参考，不能替代医疗建议。</view>
      <view class="quiz-actions">
        <view
          class="quiz-btn quiz-btn--ghost {{currentIndex === 0 ? 'quiz-btn--disabled' : ''}}"
          bindtap="prevQuestion"
        >
          上一题
        </view>
        <view class="quiz-btn quiz-btn--primary" bindtap="nextQuestion">
          {{currentIndex === questions.length - 1 ? "下一步" : "下一题"}}
        </view>
      </view>
    </view>
  </view>
</view>
