.quiz-page {
  background: transparent;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.quiz-page-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 750rpx;
  z-index: 0;
  pointer-events: none;
}

.page-top-gap,
.quiz-wrap {
  position: relative;
  z-index: 1;
}

.quiz-page .card-panel {
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
  box-shadow: none;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.quiz-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  width: 702rpx;
  margin: 32rpx auto 0;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.quiz-head {
  position: relative;
  padding-top: 0;
  min-height: auto;
}

.quiz-head__subtitle {
  margin-top: 16rpx;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 500;
}

.quiz-head__title {
  margin-top: 0;
  color: #1e293b;
  font-size: 48rpx;
  line-height: 1.24;
  font-weight: 700;
}

.quiz-head__tag {
  position: absolute;
  right: 0;
  bottom: 0;
  min-width: 128rpx;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 12rpx 12rpx 12rpx 12rpx;
  background: #cdff71;
  color: #1e293b;
  font-size: 22rpx;
  line-height: 40rpx;
  text-align: center;
  font-weight: 700;
  box-sizing: border-box;
}

.quiz-step-card {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  margin-top: 32rpx;
  padding: 24rpx 24rpx 18rpx;
  background: transparent;
}

.quiz-step-card__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.quiz-step-row,
.quiz-progress-track,
.quiz-step-notice {
  position: relative;
  z-index: 1;
}

.quiz-step-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.quiz-step-left {
  display: flex;
  align-items: flex-start;
}

.quiz-step-label {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
}

.quiz-step-title-wrap {
  margin-left: 6rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.quiz-step-title {
  color: #1e293b;
  font-size: 26rpx;
  line-height: 1.35;
  font-weight: 500;
}

.quiz-step-divider {
  margin-left: 32rpx;
  margin-right: 32rpx;
  width: 4rpx;
  height: 20rpx;
  border-radius: 2rpx 2rpx 2rpx 2rpx;
  background: #e2e8f0;
  flex-shrink: 0;
}

.quiz-step-count {
  color: #1e293b;
  line-height: 1.2;
  white-space: nowrap;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.quiz-step-count__line {
  line-height: 1.2;
}

.quiz-step-count__num {
  font-size: 36rpx;
  font-weight: 700;
}

.quiz-step-count__rest {
  font-size: 22rpx;
  font-weight: 500;
}

.quiz-step-count__dec {
  margin-top: -10rpx;
  width: 90rpx;
}

.quiz-progress-track {
  position: relative;
  height: 12rpx;
  border-radius: 10rpx;
  margin-top: 16rpx;
  background: rgba(0, 201, 80, 0.14);
  overflow: visible;
}

.quiz-progress-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 12rpx;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #00c950 0%, #77e258 100%);
}

.quiz-progress-dot {
  position: absolute;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #f8ffef;
  border: 2rpx solid #6fe066;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}

.quiz-step-notice {
  margin-top: 14rpx;
  padding: 10rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(252, 249, 235, 0.72);
  color: #634703;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
}

.quiz-card {
  margin-top: 14rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  padding: 22rpx 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.7);
}

.quiz-question-head {
  display: flex;
  align-items: flex-start;
}

.quiz-question-badge {
  flex-shrink: 0;
  width: 52rpx;
  height: 40rpx;
  border-radius: 12rpx 12rpx 12rpx 0;
  background: linear-gradient(180deg, #89dc53 0%, #06c851 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
  font-weight: 700;
}

.quiz-question-title-wrap {
  margin-left: 10rpx;
}

.quiz-options {
  margin-top: 18rpx;
}

.quiz-option {
  min-height: 88rpx;
  margin: 32rpx 0;
  border-radius: 24rpx 24rpx 24rpx 24rpx;
  border: 2rpx solid transparent;
  background: #f4f7fa;
  color: #1e293b;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx 0 26rpx;
  box-sizing: border-box;
}

.quiz-option--active {
  border-color: #00c950;
  background: #e7f7ef;
}

.quiz-option__text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #1e293b;
}

.quiz-option__indicator {
  margin-left: 16rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #cdd8e5;
  background: #ffffff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quiz-option__indicator--active {
  border-color: #00c950;
  background: #00c950;
}

.quiz-option__check {
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
}

.quiz-bottom-tip {
  margin-top: 0;
  padding-top: 0;
}

.quiz-bottom-tip__divider {
  margin: 80rpx 40rpx 40rpx;
  border-top: 2rpx dashed #cbd5e1;
}

.quiz-bottom-tip__text {
  margin-top: 14rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.56;
}

.quiz-bottom-tip__label {
  font-weight: 700;
}

.quiz-actions {
  margin-top: 80rpx;
  padding-top: 0;
  display: flex;
}

.quiz-actions--single .quiz-btn {
  margin-left: 0;
}

.quiz-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 24rpx;
  text-align: center;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.quiz-btn + .quiz-btn {
  margin-left: 18rpx;
}

.quiz-btn--ghost {
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.75);
  color: #1e293b;
}

.quiz-btn--primary {
  background: linear-gradient(90deg, #45e7cf 0%, #c7ec49 100%);
  color: #1e293b;
}

.quiz-btn--disabled {
  opacity: 0.55;
}
