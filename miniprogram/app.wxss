page {
  background: #f3f4f8;
  color: #1e293b;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  min-height: 100%;
}

.design-page {
  position: relative;
  min-height: 100vh;
  background: #f4f6f8;
  background-image: url("./assets/bg_img.png");
  background-repeat: no-repeat;
  background-position: top center;
  background-size: 750rpx auto;
}

.design-page--with-tab {
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
}

.page-top-gap {
  width: 100%;
}

.mini-nav {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  z-index: 20;
  pointer-events: none;
}

.mini-nav__inner {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding-left: 24rpx;
}

.mini-nav__back {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  pointer-events: auto;
}

.mini-nav__back-icon {
  width: 12rpx;
  height: 20rpx;
}

.mini-nav__capsule-space {
  position: absolute;
  pointer-events: none;
}

.card-panel {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 32rpx rgba(41, 77, 58, 0.08);
}

.section-title {
  color: #26323e;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-subtitle {
  color: #7a8999;
  font-size: 22rpx;
  line-height: 1.5;
}
